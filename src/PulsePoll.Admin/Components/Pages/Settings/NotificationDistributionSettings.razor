@page "/settings/notification-distribution"
@attribute [HasPermission(PermissionCodes.Settings.NotificationDistributionEdit)]
@using System.Security.Claims
@using PulsePoll.Application.DTOs
@inject INotificationDistributionConfigService ConfigService
@inject IAppToastService Toast
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Bildirim Dağıtım Ayarları — PulsePoll Admin</PageTitle>

<div class="d-flex align-items-center justify-content-between gap-2 mb-3">
    <div class="d-flex align-items-center gap-2">
        <DxButton Text="← Ayarlar"
                  RenderStyle="ButtonRenderStyle.Link"
                  Click="@(() => Nav.NavigateTo("/settings"))" />
        <h3 class="mb-0">Bildirim Dağıtım Ayarları</h3>
    </div>
    <DxButton Text="@(_isSaving ? "Kaydediliyor..." : "Ayarları Kaydet")"
              IconCssClass="bi bi-check-lg"
              RenderStyle="ButtonRenderStyle.Primary"
              RenderStyleMode="ButtonRenderStyleMode.Outline"
              Enabled="@(!_isSaving)"
              Click="SaveAsync" />
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger py-2">@_error</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <DxFormLayout>
            <DxFormLayoutGroup Caption="Dağıtım Limiti" ColSpanMd="12">
                <DxFormLayoutItem ColSpanMd="6" Caption="Saatlik Bildirim Limiti">
                    <DxSpinEdit @bind-Value="_form.HourlyLimit"
                                MinValue="1"
                                MaxValue="10000"
                                Increment="50" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>

        <div class="mt-3 text-muted small">
            Zamana yayılı dağıtım kapalı olan projelerde, yeni atanan deneklere bildirimler bu limite göre saatlik olarak gönderilir.
            Limit tüm projeler arasında eşit paylaştırılır.
        </div>
    </div>
</div>

@code {
    private NotificationDistributionForm _form = new();
    private bool _isSaving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var dto = await ConfigService.GetAsync();
        _form = NotificationDistributionForm.FromDto(dto);
    }

    private async Task SaveAsync()
    {
        _error = null;
        _isSaving = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            await ConfigService.SaveAsync(_form.ToDto(), adminId);
            Toast.Success("Bildirim dağıtım ayarları kaydedildi.");
        }
        catch (Exception ex)
        {
            _error = ErrorHandler.HandleFormSave(ex, Toast);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task<int> GetAdminIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        return claim is not null && int.TryParse(claim.Value, out var adminUserId)
            ? adminUserId
            : 0;
    }

    private sealed class NotificationDistributionForm
    {
        public int HourlyLimit { get; set; } = 300;

        public NotificationDistributionConfigDto ToDto() => new(HourlyLimit);

        public static NotificationDistributionForm FromDto(NotificationDistributionConfigDto dto)
            => new() { HourlyLimit = dto.HourlyLimit };
    }
}
