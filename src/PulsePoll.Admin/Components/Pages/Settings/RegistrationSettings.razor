@page "/settings/registration"
@attribute [HasPermission(PermissionCodes.Settings.RegistrationEdit)]
@using System.Security.Claims
@using PulsePoll.Application.DTOs
@inject IRegistrationConfigService RegistrationConfigService
@inject IAppToastService Toast
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Kayıt Ayarları — PulsePoll Admin</PageTitle>

<div class="d-flex align-items-center justify-content-between gap-2 mb-3">
    <div class="d-flex align-items-center gap-2">
        <DxButton Text="← Ayarlar"
                  RenderStyle="ButtonRenderStyle.Link"
                  Click="@(() => Nav.NavigateTo("/settings"))" />
        <span class="text-muted">/</span>
        <h3 class="mb-0">Kayıt Ayarları</h3>
    </div>
    <DxButton Text="@(_isSaving ? "Kaydediliyor..." : "Ayarları Kaydet")"
              IconCssClass="bi bi-check-lg"
              RenderStyle="ButtonRenderStyle.Primary"
              RenderStyleMode="ButtonRenderStyleMode.Outline"
              Enabled="@(!_isSaving)"
              Click="SaveAsync" />
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger py-2">@_error</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <DxFormLayout>
            <DxFormLayoutGroup Caption="Denek Onay Akışı" ColSpanMd="12">
                <DxFormLayoutItem ColSpanMd="12" Caption="Yeni Denek Onayı">
                    <DxCheckBox @bind-Checked="_form.AutoApproveNewSubjects"
                                Text="Yeni kayıt olan denekler otomatik onaylansın" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>

        <div class="mt-3 text-muted small">
            Bu seçenek kapalıysa yeni denekler beklemede açılır ve giriş yapabilmeleri için admin onayı gerekir.
        </div>
    </div>
</div>

@code {
    private RegistrationForm _form = new();
    private bool _isSaving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var dto = await RegistrationConfigService.GetAsync();
        _form = RegistrationForm.FromDto(dto);
    }

    private async Task SaveAsync()
    {
        _error = null;
        _isSaving = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            await RegistrationConfigService.SaveAsync(_form.ToDto(), adminId);
            Toast.Success("Kayıt ayarları kaydedildi.");
        }
        catch (Exception ex)
        {
            _error = ErrorHandler.HandleFormSave(ex, Toast);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task<int> GetAdminIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        return claim is not null && int.TryParse(claim.Value, out var adminUserId)
            ? adminUserId
            : 0;
    }

    private sealed class RegistrationForm
    {
        public bool AutoApproveNewSubjects { get; set; } = true;

        public RegistrationConfigDto ToDto()
            => new(AutoApproveNewSubjects);

        public static RegistrationForm FromDto(RegistrationConfigDto dto)
            => new()
            {
                AutoApproveNewSubjects = dto.AutoApproveNewSubjects
            };
    }
}
