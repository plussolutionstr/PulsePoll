@page "/settings/referral-reward"
@attribute [HasPermission(PermissionCodes.Settings.ReferralRewardEdit)]
@using System.Security.Claims
@using PulsePoll.Application.DTOs
@using PulsePoll.Application.Extensions
@using PulsePoll.Domain.Enums
@inject IReferralRewardConfigService ReferralRewardConfigService
@inject IAppToastService Toast
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Referans Ödül Ayarları — PulsePoll Admin</PageTitle>

<div class="d-flex align-items-center justify-content-between gap-2 mb-3">
    <div class="d-flex align-items-center gap-2">
        <DxButton Text="← Ayarlar"
                  RenderStyle="ButtonRenderStyle.Link"
                  Click="@(() => Nav.NavigateTo("/settings"))" />
        <span class="text-muted">/</span>
        <h3 class="mb-0">Referans Ödül Ayarları</h3>
    </div>
    <DxButton Text="@(_isSaving ? "Kaydediliyor..." : "Ayarları Kaydet")"
              IconCssClass="bi bi-check-lg"
              RenderStyle="ButtonRenderStyle.Primary"
              RenderStyleMode="ButtonRenderStyleMode.Outline"
              Enabled="@(!_isSaving)"
              Click="SaveAsync" />
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger py-2">@_error</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <DxFormLayout>
            <DxFormLayoutGroup Caption="Ödül Kuralı" ColSpanMd="12">
                <DxFormLayoutItem ColSpanMd="4" Caption="Aktif">
                    <DxCheckBox @bind-Checked="_form.IsActive" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" Caption="Ödül Tutarı (Birim)">
                    <DxSpinEdit @bind-Value="_form.RewardAmount"
                                MinValue="0m"
                                Increment="1m"
                                DisplayFormat="N2" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" Caption="Tetikleyici">
                    <DxComboBox Data="@_triggerOptions"
                                @bind-Value="_form.TriggerType"
                                ValueFieldName="Value"
                                TextFieldName="Label"
                                NullText="Seçiniz..." />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4"
                                  Caption="Aktif Gün Eşiği"
                                  Visible="@(_form.TriggerType == ReferralRewardTriggerType.ActiveDaysReached)">
                    <DxSpinEdit @bind-Value="_form.ActiveDaysThreshold"
                                MinValue="1"
                                MaxValue="3650"
                                Increment="1" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>

        <div class="mt-3 text-muted small">
            Not: Ödül yalnızca bir kez verilir. Aynı referans için tekrar kredi yazılmaz.
        </div>
    </div>
</div>

@code {
    private ReferralRewardForm _form = new();
    private readonly List<TriggerOption> _triggerOptions =
        Enum.GetValues<ReferralRewardTriggerType>()
            .Select(x => new TriggerOption(x, x.GetDescription()))
            .ToList();
    private bool _isSaving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var dto = await ReferralRewardConfigService.GetAsync();
        _form = ReferralRewardForm.FromDto(dto);
    }

    private async Task SaveAsync()
    {
        _error = null;
        _isSaving = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            await ReferralRewardConfigService.SaveAsync(_form.ToDto(), adminId);
            Toast.Success("Referans ödül ayarları kaydedildi.");
        }
        catch (Exception ex)
        {
            _error = ErrorHandler.HandleFormSave(ex, Toast);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task<int> GetAdminIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        return claim is not null && int.TryParse(claim.Value, out var adminUserId)
            ? adminUserId
            : 0;
    }

    private sealed class ReferralRewardForm
    {
        public bool IsActive { get; set; } = true;
        public decimal RewardAmount { get; set; } = 10m;
        public ReferralRewardTriggerType TriggerType { get; set; } = ReferralRewardTriggerType.FirstRewardApproved;
        public int ActiveDaysThreshold { get; set; } = 7;

        public ReferralRewardConfigDto ToDto()
            => new(IsActive, RewardAmount, TriggerType, ActiveDaysThreshold);

        public static ReferralRewardForm FromDto(ReferralRewardConfigDto dto)
            => new()
            {
                IsActive = dto.IsActive,
                RewardAmount = dto.RewardAmount,
                TriggerType = dto.TriggerType,
                ActiveDaysThreshold = dto.ActiveDaysThreshold
            };
    }

    private sealed record TriggerOption(
        ReferralRewardTriggerType Value,
        string Label);
}
