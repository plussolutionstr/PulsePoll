@page "/media-library"
@attribute [HasPermission(PermissionCodes.MediaLibrary.View)]
@using System.Security.Claims
@inject IMediaAssetService MediaAssetService
@inject IAppToastService Toast
@inject AuthenticationStateProvider AuthStateProvider
@inject IPermissionAuthorizationService PermissionService

<PageTitle>Medya Kütüphanesi — PulsePoll Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Medya Kütüphanesi</h3>
    @if (_canUpload)
    {
        <DxButton Text="Görsel Yükle" IconCssClass="bi bi-upload"
                  RenderStyle="ButtonRenderStyle.Primary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="OnUploadClick" />
    }
</div>

<DxLoadingPanel @bind-Visible="_isLoading"
                IsContentBlocked="true"
                ApplyBackgroundShading="true"
                IndicatorAreaVisible="false"
                Text="Yükleniyor...">
    @if (_assets.Count == 0 && !_isLoading)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-images" style="font-size:3rem;"></i>
            <p class="mt-2">Henüz görsel yüklenmedi.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-md-4 g-3">
            @foreach (var asset in _assets)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div style="width:120px; height:120px; margin:auto; background:#f8f9fa; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                            <img src="@asset.Url"
                                 style="max-width:120px; max-height:120px; object-fit:contain;"
                                 alt="@asset.Name" />
                        </div>
                        <div class="card-body p-2">
                            <p class="card-title mb-1 small fw-semibold text-truncate" title="@asset.Name">@asset.Name</p>
                            <p class="card-text text-muted" style="font-size:0.75rem;">
                                @FormatSize(asset.Size)
                                @if (asset.UsageCount > 0)
                                {
                                    <span class="ms-2 badge bg-info text-dark">@asset.UsageCount projede</span>
                                }
                            </p>
                        </div>
                        <div class="card-footer p-1 text-end border-top-0">
                            <DxButton IconCssClass="bi bi-trash"
                                      RenderStyle="ButtonRenderStyle.Danger"
                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                      SizeMode="SizeMode.Small"
                                      Visible="@_canDelete"
                                      title="Sil"
                                      Click="@(() => ShowDeleteConfirm(asset))" />
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</DxLoadingPanel>

<!-- Toplu Yükleme Popup -->
<DxPopup @bind-Visible="_uploadPopupVisible"
         HeaderText="Görsel Yükle"
         Width="600px"
         CloseOnOutsideClick="false"
         ShowFooter="true">
    <BodyContentTemplate Context="_">
        <div class="mb-3">
            <DxFileInput MaxFileSize="5242880"
                         MaxFileCount="20"
                         FilesUploading="OnFilesUploading"
                         AcceptedFileTypes="@_acceptedTypes"
                         DropZoneContainerCssSelector="#upload-drop-zone"
                         DropZoneDragOverCssClass="drop-zone-active" />
            <div id="upload-drop-zone"
                 class="border border-2 border-dashed rounded-3 text-center text-muted p-4 mt-2"
                 style="min-height:120px; display:flex; align-items:center; justify-content:center; flex-direction:column; cursor:pointer;">
                <i class="bi bi-cloud-arrow-up" style="font-size:2.5rem;"></i>
                <p class="mb-0 mt-2">Görselleri buraya sürükleyin veya yukarıdan seçin</p>
                <p class="small mb-0">JPG, PNG, GIF, WebP — maks. 5 MB / dosya — en fazla 20 dosya</p>
            </div>
        </div>
        @if (_pendingFiles.Count > 0)
        {
            <div class="mt-2" style="max-height:260px; overflow-y:auto;">
                <table class="table table-sm table-borderless mb-0">
                    @foreach (var pf in _pendingFiles)
                    {
                        <tr>
                            <td style="width:50px;">
                                <img src="@($"data:{pf.ContentType};base64,{Convert.ToBase64String(pf.Bytes)}")"
                                     style="width:40px; height:40px; object-fit:contain; border:1px solid #dee2e6; border-radius:4px;"
                                     alt="Önizleme" />
                            </td>
                            <td class="align-middle">
                                <span class="small fw-semibold text-truncate d-inline-block" style="max-width:280px;" title="@pf.FileName">@pf.FileName</span>
                                <span class="small text-muted ms-2">@FormatSize(pf.Bytes.LongLength)</span>
                            </td>
                            <td class="align-middle text-end" style="width:36px;">
                                @if (pf.Status == UploadFileStatus.Pending)
                                {
                                    <DxButton IconCssClass="bi bi-x"
                                              RenderStyle="ButtonRenderStyle.Danger"
                                              RenderStyleMode="ButtonRenderStyleMode.Text"
                                              SizeMode="SizeMode.Small"
                                              Click="@(() => _pendingFiles.Remove(pf))" />
                                }
                                else if (pf.Status == UploadFileStatus.Uploaded)
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else if (pf.Status == UploadFileStatus.Failed)
                                {
                                    <i class="bi bi-exclamation-circle-fill text-danger" title="@pf.Error"></i>
                                }
                            </td>
                        </tr>
                    }
                </table>
            </div>
        }
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="@(_isUploading ? $"Yükleniyor... ({_uploadedCount}/{_pendingFiles.Count})" : $"Tümünü Yükle ({_pendingFiles.Count(f => f.Status == UploadFileStatus.Pending)})")"
                  IconCssClass="@(_isUploading ? "spinner-border spinner-border-sm" : "bi bi-upload")"
                  RenderStyle="ButtonRenderStyle.Primary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="DoUploadAll"
                  Enabled="@(_pendingFiles.Any(f => f.Status == UploadFileStatus.Pending) && !_isUploading)" />
        <DxButton Text="Kapat"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="CloseUploadPopup"
                  Enabled="@(!_isUploading)" />
    </FooterContentTemplate>
</DxPopup>

<!-- Silme Onay Popup -->
<DxPopup @bind-Visible="_deleteConfirmVisible"
         HeaderText="Silme Onayı"
         Width="420px"
         CloseOnOutsideClick="false"
         ShowFooter="true">
    <BodyContentTemplate Context="_">
        <div class="d-flex align-items-start gap-3 p-2">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:2.5rem; flex-shrink:0;"></i>
            <div>
                <p class="mb-1 fw-semibold">Bu görseli silmek istediğinize emin misiniz?</p>
                <p class="mb-0 text-muted">@_assetToDelete?.Name</p>
            </div>
        </div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="Sil" IconCssClass="bi bi-trash"
                  RenderStyle="ButtonRenderStyle.Danger"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="ConfirmDelete"
                  Enabled="!_isDeleting" />
        <DxButton Text="İptal"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="() => _deleteConfirmVisible = false" />
    </FooterContentTemplate>
</DxPopup>

@code {
    private List<MediaAssetDto> _assets = [];
    private bool _isLoading = true;
    private bool _canUpload;
    private bool _canDelete;

    // Yükleme
    private bool _uploadPopupVisible;
    private bool _isUploading;
    private int _uploadedCount;
    private List<PendingFile> _pendingFiles = [];
    private readonly List<string> _acceptedTypes = [".jpg", ".jpeg", ".png", ".gif", ".webp"];

    // Silme
    private bool _deleteConfirmVisible;
    private bool _isDeleting;
    private MediaAssetDto? _assetToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();
        await LoadDataAsync();
    }

    private async Task LoadPermissionsAsync()
    {
        var permissions = await PermissionService.GetCurrentPermissionsAsync();
        _canUpload = permissions.Contains(PermissionCodes.MediaLibrary.Upload);
        _canDelete = permissions.Contains(PermissionCodes.MediaLibrary.Delete);
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _assets = await MediaAssetService.GetAllAsync();
        _isLoading = false;
    }

    private void OnUploadClick()
    {
        if (!_canUpload)
        {
            Toast.Error("Medya yükleme yetkiniz yok.");
            return;
        }

        _pendingFiles = [];
        _uploadedCount = 0;
        _uploadPopupVisible = true;
    }

    private void CloseUploadPopup()
    {
        _uploadPopupVisible = false;
        _pendingFiles = [];
        _uploadedCount = 0;
    }

    private async Task OnFilesUploading(FilesUploadingEventArgs args)
    {
        foreach (var file in args.Files)
        {
            if (_pendingFiles.Any(p => p.FileName == file.Name))
                continue;

            var contentType = string.IsNullOrEmpty(file.Type)
                ? GetContentTypeFromExtension(file.Name)
                : file.Type;

            var bytes = new byte[(int)file.Size];
            var stream = file.OpenReadStream((long)file.Size);
            try
            {
                int read, offset = 0;
                while ((read = await stream.ReadAsync(bytes, offset, (int)file.Size - offset)) > 0)
                    offset += read;
            }
            finally
            {
                stream.Close();
            }

            _pendingFiles.Add(new PendingFile(file.Name, contentType, bytes));
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task DoUploadAll()
    {
        if (!_canUpload)
        {
            Toast.Error("Medya yükleme yetkiniz yok.");
            return;
        }

        var pending = _pendingFiles.Where(f => f.Status == UploadFileStatus.Pending).ToList();
        if (pending.Count == 0) return;

        _isUploading = true;
        _uploadedCount = 0;
        try
        {
            var adminId = await GetAdminIdAsync();
            foreach (var pf in pending)
            {
                try
                {
                    using var ms = new MemoryStream(pf.Bytes, false);
                    await MediaAssetService.UploadAsync(ms, pf.FileName, pf.ContentType, pf.Bytes.LongLength, adminId);
                    pf.Status = UploadFileStatus.Uploaded;
                }
                catch (Exception ex)
                {
                    pf.Status = UploadFileStatus.Failed;
                    pf.Error = ex.Message;
                }
                _uploadedCount++;
                await InvokeAsync(StateHasChanged);
            }

            var successCount = pending.Count(f => f.Status == UploadFileStatus.Uploaded);
            var failCount = pending.Count(f => f.Status == UploadFileStatus.Failed);

            if (failCount == 0)
                Toast.Success($"{successCount} görsel yüklendi.");
            else
                Toast.Warning($"{successCount} yüklendi, {failCount} başarısız.");

            await LoadDataAsync();
        }
        finally
        {
            _isUploading = false;
        }
    }

    private void ShowDeleteConfirm(MediaAssetDto asset)
    {
        if (!_canDelete)
        {
            Toast.Error("Medya silme yetkiniz yok.");
            return;
        }

        _assetToDelete        = asset;
        _deleteConfirmVisible = true;
    }

    private async Task ConfirmDelete()
    {
        if (!_canDelete)
        {
            Toast.Error("Medya silme yetkiniz yok.");
            return;
        }

        if (_assetToDelete is null) return;

        _isDeleting = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            await MediaAssetService.DeleteAsync(_assetToDelete.Id, adminId);
            _deleteConfirmVisible = false;
            _assetToDelete        = null;
            await LoadDataAsync();
            Toast.Success("Görsel silindi.");
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast, "Silme işlemi başarısız.");
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task<int> GetAdminIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        return claim is not null && int.TryParse(claim.Value, out var adminUserId)
            ? adminUserId
            : 0;
    }

    private static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024
            ? $"{bytes / 1024.0 / 1024.0:F1} MB"
            : $"{bytes / 1024.0:F0} KB";

    private static string GetContentTypeFromExtension(string fileName) =>
        Path.GetExtension(fileName).ToLowerInvariant() switch
        {
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png"            => "image/png",
            ".gif"            => "image/gif",
            ".webp"           => "image/webp",
            _                 => "application/octet-stream"
        };

    private sealed class PendingFile(string fileName, string contentType, byte[] bytes)
    {
        public string FileName { get; } = fileName;
        public string ContentType { get; } = contentType;
        public byte[] Bytes { get; } = bytes;
        public UploadFileStatus Status { get; set; } = UploadFileStatus.Pending;
        public string? Error { get; set; }
    }

    private enum UploadFileStatus { Pending, Uploaded, Failed }
}
