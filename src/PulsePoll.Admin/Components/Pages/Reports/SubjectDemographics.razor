@page "/reports/subject-demographics"
@attribute [HasPermission(PermissionCodes.Reports.View)]
@inject IReportService ReportService
@inject IAppToastService Toast
@inject IJSRuntime JS

<PageTitle>Demografik Dağılım — PulsePoll Admin</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <h3 class="mb-0">Demografik Dağılım Raporu</h3>
</div>

@if (_isLoading)
{
    <div class="demo-widget">
        <div class="text-muted py-3">Veriler yükleniyor...</div>
    </div>
}
else if (_result is not null)
{
    @* Genel Özet Kartları *@
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="demo-summary-card">
                <div class="demo-summary-label">Toplam Onaylı Denek</div>
                <div class="demo-summary-value">@_result.GrandTotal.ToString("N0")</div>
                <div class="demo-summary-pct">&nbsp;</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="demo-summary-card demo-female">
                <div class="demo-summary-label">Kadın</div>
                <div class="demo-summary-value">@_result.TotalFemale.ToString("N0")</div>
                <div class="demo-summary-pct">@Pct(_result.TotalFemale, _result.GrandTotal)</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="demo-summary-card demo-male">
                <div class="demo-summary-label">Erkek</div>
                <div class="demo-summary-value">@_result.TotalMale.ToString("N0")</div>
                <div class="demo-summary-pct">@Pct(_result.TotalMale, _result.GrandTotal)</div>
            </div>
        </div>
    </div>

    @* Hızlı Navigasyon *@
    <div class="demo-nav mb-4">
        @foreach (var sect in _result.Sections)
        {
            <a @onclick="() => ScrollToSection(sect.GroupName)" @onclick:preventDefault class="demo-nav-item" href="">@sect.GroupName</a>
        }
    </div>

    @* Bölümler *@
    @foreach (var sect in _result.Sections)
    {
        <div id="section-@sect.GroupName.Replace(" ", "-")" class="demo-section mb-4">
            <div class="demo-section-header">
                <h5 class="mb-0 fw-bold">@sect.GroupName</h5>
                <span class="text-muted">@sect.GrandTotal.ToString("N0") denek</span>
            </div>

            @* Bar Chart *@
            @if (sect.Rows.Count <= 20)
            {
                <div class="demo-bars mb-3">
                    @foreach (var row in sect.Rows)
                    {
                        var pctFemale = sect.GrandTotal > 0 ? (double)row.FemaleCount / sect.GrandTotal * 100 : 0;
                        var pctMale = sect.GrandTotal > 0 ? (double)row.MaleCount / sect.GrandTotal * 100 : 0;
                        var pctTotal = sect.GrandTotal > 0 ? (double)row.TotalCount / sect.GrandTotal * 100 : 0;

                        <div class="demo-bar-row">
                            <div class="demo-bar-label" title="@row.Value">@row.Value</div>
                            <div class="demo-bar-track">
                                <div class="demo-bar-fill demo-bar-female" style="width: @($"{pctFemale:0.##}")%"></div>
                                <div class="demo-bar-fill demo-bar-male" style="width: @($"{pctMale:0.##}")%"></div>
                            </div>
                            <div class="demo-bar-count">@row.TotalCount.ToString("N0")</div>
                        </div>
                    }
                </div>
            }

            @* Tablo *@
            <div class="table-responsive">
                <table class="table table-sm table-hover demo-table mb-0">
                    <thead>
                        <tr>
                            <th>@sect.GroupName</th>
                            <th class="text-end">Kadın</th>
                            <th class="text-end">Erkek</th>
                            <th class="text-end fw-bold">Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in sect.Rows)
                        {
                            <tr>
                                <td>@row.Value</td>
                                <td class="text-end">@row.FemaleCount.ToString("N0")</td>
                                <td class="text-end">@row.MaleCount.ToString("N0")</td>
                                <td class="text-end fw-bold">@row.TotalCount.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-active fw-bold">
                            <td>TOPLAM</td>
                            <td class="text-end">@sect.TotalFemale.ToString("N0")</td>
                            <td class="text-end">@sect.TotalMale.ToString("N0")</td>
                            <td class="text-end">@sect.GrandTotal.ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
}

@code {
    private bool _isLoading = true;
    private SubjectDemographicsResultDto? _result;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _result = await ReportService.GetSubjectDemographicsAsync();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleFormSave(ex, Toast);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ScrollToSection(string groupName)
    {
        var id = "section-" + groupName.Replace(" ", "-");
        await JS.InvokeVoidAsync("document.getElementById", id);
        await JS.InvokeVoidAsync("eval", $"document.getElementById('{id}')?.scrollIntoView({{behavior:'smooth',block:'start'}})");
    }

    private static string Pct(int part, int total)
        => total <= 0 ? "%0" : $"%{(decimal)part / total * 100m:0.#}";
}
