@page "/payments/withdrawals"
@attribute [HasPermission(PermissionCodes.Payments.WithdrawalsView)]
@using System.Security.Claims
@inject IAdminGridDataService AdminGridDataService
@inject IPaymentBatchService PaymentBatchService
@inject ILogger<WithdrawalRequests> Logger
@inject IAppToastService Toast
@inject AuthenticationStateProvider AuthStateProvider
@inject IPermissionAuthorizationService PermissionService

<PageTitle>Çekim Talepleri - PulsePoll Admin</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-2">
    <h3 class="mb-0">Çekim Talepleri</h3>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "pending" ? "active" : "")" @onclick='() => SetTab("pending")'>
            Bekleyen
            @if (_pendingTotal > 0) { <span class="badge bg-warning text-dark ms-1">@_pendingTotal</span> }
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "approved" ? "active" : "")" @onclick='() => SetTab("approved")'>
            Onaylanan (Pakete Eklenmemiş)
            @if (_approvedTotal > 0) { <span class="badge bg-success ms-1">@_approvedTotal</span> }
        </button>
    </li>
</ul>

<div class="d-flex justify-content-end mb-2">
    @if (_activeTab == "pending")
    {
        <DxButton Text="Tümünü Seç"
                  IconCssClass="bi bi-check2-square"
                  CssClass="me-2"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Enabled="@(!_isActionRunning && _pendingTotal > 0)"
                  Click="SelectAllPendingAsync"/>
        <DxButton Text="Seçimi Temizle"
                  IconCssClass="bi bi-x-square"
                  CssClass="me-2"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Enabled="@(!_isActionRunning && SelectedPendingCount > 0)"
                  Click="ClearSelection"/>
        @if (_canApprove)
        {
            <DxButton Text="Seçilenleri Onayla"
                      IconCssClass="bi bi-check2-circle"
                      CssClass="me-2"
                      RenderStyle="ButtonRenderStyle.Success"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      Enabled="@(!_isActionRunning && SelectedPendingCount > 0)"
                      Click="OnBulkApproveAsync"/>
        }
        @if (_canReject)
        {
            <DxButton Text="Seçilenleri Reddet"
                      IconCssClass="bi bi-x-circle"
                      CssClass="me-2"
                      RenderStyle="ButtonRenderStyle.Danger"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      Enabled="@(!_isActionRunning && SelectedPendingCount > 0)"
                      Click="OnBulkRejectClick"/>
        }
    }
    @if (_canExport && _activeTab == "pending")
    {
        <DxButton Text="Excel"
                  IconCssClass="bi bi-file-earmark-excel"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="ExportToExcelAsync"/>
    }
    else if (_canExport)
    {
        <DxButton Text="Excel"
                  IconCssClass="bi bi-file-earmark-excel"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="ExportToExcelAsync"/>
    }
</div>

<DxGrid @ref="_grid"
        Data="@_dataSource"
        KeyFieldName="Id"
        SelectionMode="GridSelectionMode.Multiple"
        @bind-SelectedDataItems="_selectedRows"
        ShowFilterRow="true"
        PageSize="25"
        ColumnResizeMode="GridColumnResizeMode.ColumnsContainer">
    <Columns>
        @if (_activeTab == "pending")
        {
            <DxGridSelectionColumn Width="40px"/>
        }
        <DxGridDataColumn FieldName="Id" Caption="ID" Width="70px"/>
        <DxGridDataColumn FieldName="Subject.FullName" Caption="Denek" MinWidth="150"/>
        <DxGridDataColumn FieldName="BankAccount.BankName" Caption="Banka" Width="130px"/>
        <DxGridDataColumn FieldName="BankAccount.IbanEncrypted" Caption="IBAN" MinWidth="220"/>
        <DxGridDataColumn FieldName="Amount" Caption="Tutar (Birim)" Width="140px">
            <CellDisplayTemplate>
                @{
                    var rowItem = (WithdrawalRequest)context.DataItem;
                }
                @($"{rowItem.Amount:N2} {rowItem.UnitLabel}")
            </CellDisplayTemplate>
        </DxGridDataColumn>
        <DxGridDataColumn FieldName="AmountTry" Caption="TL Karşılığı" DisplayFormat="N2" Width="120px"/>
        <DxGridDataColumn FieldName="Status" Caption="Durum" Width="110px">
            <CellDisplayTemplate>
                @{
                    var rowItem = (WithdrawalRequest)context.DataItem;
                }
                <span class="badge @StatusBadge(rowItem.Status)">@StatusLabel(rowItem.Status)</span>
            </CellDisplayTemplate>
        </DxGridDataColumn>
        <DxGridDataColumn FieldName="CreatedAt" Caption="Talep Tarihi" DisplayFormat="dd.MM.yyyy HH:mm" Width="150px"/>
        <DxGridDataColumn FieldName="RejectionReason" Caption="Red Nedeni" MinWidth="150"/>
        @if (_activeTab == "pending")
        {
            <DxGridCommandColumn Width="130px" Caption="İşlemler" NewButtonVisible="false">
                <CellDisplayTemplate>
                    @{
                        var rowItem2 = (WithdrawalRequest)context.DataItem;
                    }
                    <div class="d-flex gap-1">
                        @if (_canApprove)
                        {
                            <DxButton Text="Onayla"
                                      RenderStyle="ButtonRenderStyle.Success"
                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                      SizeMode="SizeMode.Small"
                                      Click="@(() => OnApproveClick(rowItem2))"/>
                        }
                        @if (_canReject)
                        {
                            <DxButton Text="Reddet"
                                      RenderStyle="ButtonRenderStyle.Danger"
                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                      SizeMode="SizeMode.Small"
                                      Click="@(() => OnRejectClick(rowItem2))"/>
                        }
                    </div>
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        }
    </Columns>
    <TotalSummary>
        <DxGridSummaryItem SummaryType="GridSummaryItemType.Count"
                           FieldName="Id"
                           FooterColumnName="Subject.FullName"
                           DisplayText="Kayıt Sayısı: {0}" />
        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                           FieldName="AmountTry"
                           FooterColumnName="AmountTry"
                           DisplayText="Toplam Tutar: {0:N2} TL" />
    </TotalSummary>
</DxGrid>

<DxPopup @bind-Visible="_rejectPopupVisible" HeaderText="Talebi Reddet" Width="420px" CloseOnOutsideClick="false" ShowFooter="true">
    <BodyContentTemplate Context="popupCtx">
        <DxFormLayout>
            <DxFormLayoutItem Caption="Seçili Talep" ColSpanMd="12">
                <div class="small text-muted">@_rejectTargetLabel</div>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Red Nedeni" ColSpanMd="12">
                <DxMemo @bind-Text="_rejectReason" Rows="3" style="width:100%"/>
            </DxFormLayoutItem>
        </DxFormLayout>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="Reddet"
                  RenderStyle="ButtonRenderStyle.Danger"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="ConfirmRejectAsync"/>
        <DxButton Text="İptal"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Click="() => _rejectPopupVisible = false"/>
    </FooterContentTemplate>
</DxPopup>

@code {
    DxGrid? _grid;
    string _activeTab = "pending";
    int _pendingTotal;
    int _approvedTotal;
    bool _canApprove;
    bool _canReject;
    bool _canExport;
    bool _isActionRunning;

    GridDevExtremeDataSource<WithdrawalRequest>? _dataSource;

    WithdrawalRequest? _selectedItem;
    IReadOnlyList<object> _selectedRows = [];
    List<int> _rejectIds = [];
    string _rejectTargetLabel = string.Empty;
    bool _rejectPopupVisible;
    string _rejectReason = string.Empty;
    int SelectedPendingCount => _selectedRows.Count;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();
        await LoadCountsAsync();
        RecreateDataSource();
    }

    private void RecreateDataSource()
    {
        var query = _activeTab == "pending"
            ? AdminGridDataService.GetPendingWithdrawalsQuery()
            : AdminGridDataService.GetApprovedWithoutBatchWithdrawalsQuery();

        _dataSource = new GridDevExtremeDataSource<WithdrawalRequest>(query);
    }

    private async Task LoadPermissionsAsync()
    {
        var permissions = await PermissionService.GetCurrentPermissionsAsync();
        _canApprove = permissions.Contains(PermissionCodes.Payments.WithdrawalsApprove);
        _canReject = permissions.Contains(PermissionCodes.Payments.WithdrawalsReject);
        _canExport = permissions.Contains(PermissionCodes.Payments.WithdrawalsExport);
    }

    private async Task LoadCountsAsync()
    {
        var (_, pt) = await PaymentBatchService.GetPendingWithdrawalsAsync(0, 1);
        var (_, at) = await PaymentBatchService.GetApprovedWithdrawalsAsync(0, 1);
        _pendingTotal  = pt;
        _approvedTotal = at;
    }

    private async Task SetTab(string tab)
    {
        _activeTab = tab;
        _selectedRows = [];
        await LoadCountsAsync();
        RecreateDataSource();
    }

    private async Task OnApproveClick(WithdrawalRequest item)
    {
        if (!_canApprove)
        {
            Toast.Error("Çekim onaylama yetkiniz yok.");
            return;
        }

        var adminId = await GetAdminIdAsync();
        try
        {
            await PaymentBatchService.ApproveWithdrawalAsync(item.Id, adminId);
            Toast.Success("Talep onaylandı.");
            _selectedRows = _selectedRows
                .Where(x => x is not WithdrawalRequest wr || wr.Id != item.Id)
                .ToList();
            await LoadCountsAsync();
            RecreateDataSource();
        }
        catch (Exception ex) { ErrorHandler.HandleOperation(ex, Toast); }
    }

    private void OnRejectClick(WithdrawalRequest item)
    {
        if (!_canReject)
        {
            Toast.Error("Çekim reddetme yetkiniz yok.");
            return;
        }

        _selectedItem       = item;
        _rejectIds          = [item.Id];
        _rejectTargetLabel  = $"1 talep: #{item.Id}";
        _rejectReason       = string.Empty;
        _rejectPopupVisible = true;
    }

    private async Task OnBulkApproveAsync()
    {
        if (!_canApprove)
        {
            Toast.Error("Çekim onaylama yetkiniz yok.");
            return;
        }

        var selectedIds = await GetSelectedPendingIdsAsync();
        if (selectedIds.Count == 0)
        {
            Toast.Error("Lütfen en az bir bekleyen talep seçin.");
            return;
        }

        var adminId = await GetAdminIdAsync();
        _isActionRunning = true;
        var approvedCount = 0;
        var failedCount = 0;
        try
        {
            foreach (var id in selectedIds)
            {
                try
                {
                    await PaymentBatchService.ApproveWithdrawalAsync(id, adminId);
                    approvedCount++;
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Toplu çekim onayında kayıt işlenemedi: RequestId={RequestId}", id);
                    failedCount++;
                }
            }

            if (approvedCount > 0)
                Toast.Success($"{approvedCount} talep onaylandı.");
            else
                Toast.Error("Seçili talepler onaylanamadı.");

            if (failedCount > 0)
                Toast.Warning($"{failedCount} talep hata nedeniyle atlandı.");
        }
        finally
        {
            _isActionRunning = false;
            _selectedRows = [];
            await LoadCountsAsync();
            RecreateDataSource();
        }
    }

    private void OnBulkRejectClick()
    {
        if (!_canReject)
        {
            Toast.Error("Çekim reddetme yetkiniz yok.");
            return;
        }

        var selectedIds = GetSelectedPendingIds();
        if (selectedIds.Count == 0)
        {
            Toast.Error("Lütfen en az bir bekleyen talep seçin.");
            return;
        }

        _selectedItem = null;
        _rejectIds = selectedIds;
        _rejectTargetLabel = $"{_rejectIds.Count} talep seçildi.";
        _rejectReason = string.Empty;
        _rejectPopupVisible = true;
    }

    private async Task ConfirmRejectAsync()
    {
        if (!_canReject)
        {
            Toast.Error("Çekim reddetme yetkiniz yok.");
            return;
        }

        if (string.IsNullOrWhiteSpace(_rejectReason))
        {
            Toast.Error("Red nedeni zorunludur.");
            return;
        }
        if (_rejectIds.Count == 0 && _selectedItem is not null)
            _rejectIds = [_selectedItem.Id];

        if (_rejectIds.Count == 0)
        {
            Toast.Error("Reddedilecek talep bulunamadı.");
            return;
        }

        var adminId = await GetAdminIdAsync();
        _rejectPopupVisible = false;
        _isActionRunning = true;
        var rejectedCount = 0;
        var failedCount = 0;
        try
        {
            foreach (var id in _rejectIds.Distinct())
            {
                try
                {
                    await PaymentBatchService.RejectWithdrawalAsync(id, _rejectReason, adminId);
                    rejectedCount++;
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Toplu çekim reddinde kayıt işlenemedi: RequestId={RequestId}", id);
                    failedCount++;
                }
            }

            if (rejectedCount > 0)
                Toast.Success($"{rejectedCount} talep reddedildi, tutar iade edildi.");
            else
                Toast.Error("Seçili talepler reddedilemedi.");

            if (failedCount > 0)
                Toast.Warning($"{failedCount} talep hata nedeniyle atlandı.");
        }
        catch (Exception ex) { ErrorHandler.HandleOperation(ex, Toast); }
        finally
        {
            _isActionRunning = false;
            _selectedRows = [];
            _rejectIds.Clear();
            _rejectTargetLabel = string.Empty;
            await LoadCountsAsync();
            RecreateDataSource();
        }
    }

    private static string StatusBadge(ApprovalStatus status) => status switch
    {
        ApprovalStatus.Pending  => "bg-warning text-dark",
        ApprovalStatus.Approved => "bg-success",
        ApprovalStatus.Rejected => "bg-danger",
        _                       => "bg-secondary"
    };

    private static string StatusLabel(ApprovalStatus status) => status switch
    {
        ApprovalStatus.Pending  => "Bekliyor",
        ApprovalStatus.Approved => "Onaylı",
        ApprovalStatus.Rejected => "Reddedildi",
        _                       => status.ToString()
    };

    private async Task<int> GetAdminIdAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return int.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var adminId)
            ? adminId
            : 0;
    }

    private async Task ExportToExcelAsync()
    {
        if (!_canExport)
        {
            Toast.Error("Çekim dışa aktarma yetkiniz yok.");
            return;
        }

        if (_grid is null)
            return;

        var fileName = _activeTab == "pending" ? "çekim-talepleri-bekleyen" : "çekim-talepleri-onaylanan";
        try
        {
            await _grid.ExportToXlsxAsync(fileName);
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast);
        }
    }

    private async Task SelectAllPendingAsync()
    {
        var allPendingRows = await AdminGridDataService.GetAllPendingWithdrawalsAsync();

        _selectedRows = allPendingRows.Cast<object>().ToList();
    }

    private void ClearSelection()
    {
        _selectedRows = [];
    }

    private List<int> GetSelectedPendingIds()
        => _selectedRows
            .OfType<WithdrawalRequest>()
            .Select(w => w.Id)
            .Distinct()
            .ToList();

    private async Task<List<int>> GetSelectedPendingIdsAsync()
    {
        var selectedIds = GetSelectedPendingIds();
        if (selectedIds.Count == 0)
            return [];

        return await AdminGridDataService.GetPendingWithdrawalIdsAsync(selectedIds);
    }
}
