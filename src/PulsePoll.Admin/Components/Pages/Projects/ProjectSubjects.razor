    private async Task CancelJobAsync(int jobId)
    {
        if (!_canManageSubjects)
        {
            Toast.Error("Atama işi iptal etme yetkiniz yok.");
            return;
        }

        try
        {
            await AssignmentService.CancelJobAsync(jobId);
            Toast.Warning("Atama işlemi iptal edildi.");
            _pollCts?.Cancel();
            await RefreshJobsAsync();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast);
        }
    }

    private void StartPolling()
    {
        _pollCts?.Cancel();
        _pollCts = new CancellationTokenSource();
        _ = PollJobsAsync(_pollCts.Token);
    }

    private async Task PollJobsAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                try
                {
                    _jobs = await AssignmentService.GetJobsAsync(ProjectId);

                    if (_jobs.Any(j => j.Status == AssignmentJobStatus.Completed))
                        await LoadAssignmentsAsync();

                    await InvokeAsync(StateHasChanged);

                    if (!_jobs.Any(j => j.Status is AssignmentJobStatus.Pending or AssignmentJobStatus.Processing))
                        break;
                }
                catch (Exception) when (!ct.IsCancellationRequested)
                {
                    // geçici hata — polling devam etsin
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }
}
