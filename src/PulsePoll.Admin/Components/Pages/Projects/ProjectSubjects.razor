    {
        if (_grid is not null)
            await _grid.SelectAllAsync();
    }

    private async Task DeselectAllAsync()
    {
        if (_grid is not null)
            await _grid.DeselectAllAsync();
    }

    private async Task AssignAsync()
    {
        if (!_canManageSubjects)
        {
            Toast.Error("Denek atama yetkiniz yok.");
            return;
        }

        if (IsProjectClosed)
        {
            Toast.Warning("Kapalı projeye yeni denek atanamaz.");
            return;
        }

        var selected = _selectedSubjects.Cast<Subject>().ToList();

        var ids = selected
            .Where(s => s.Status == ApprovalStatus.Approved && !_assignedSubjectIds.Contains(s.Id))
            .Select(s => s.Id)
            .ToList();

        var skippedNotApproved = selected
            .Count(s => s.Status != ApprovalStatus.Approved && !_assignedSubjectIds.Contains(s.Id));

        if (skippedNotApproved > 0)
            Toast.Warning($"{skippedNotApproved} onaylanmamış denek atlamaya alındı.");

        if (ids.Count == 0) return;

        _isAssigning = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            var jobId = await AssignmentService.RequestBulkAssignAsync(ProjectId, ids, adminId);
            Toast.Success($"{ids.Count} denek kuyruğa gönderildi. (İş #{jobId})");
            await _grid!.DeselectAllAsync();
            await RefreshJobsAsync();
            StartPolling();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast);
        }
        finally
        {
            _isAssigning = false;
        }
    }

    private async Task ToggleProjectStatusAsync()
    {
        if (!_canToggleStatus)
        {
            Toast.Error("Proje durumu değiştirme yetkiniz yok.");
            return;
        }

        try
        {
            var wasClosed = IsProjectClosed;
            var adminId = await GetAdminIdAsync();
            var targetStatus = wasClosed ? ProjectStatus.Active : ProjectStatus.Completed;
            await ProjectService.SetStatusAsync(ProjectId, targetStatus, adminId);
            _projectStatus = targetStatus;

            Toast.Success(wasClosed
                ? "Proje tekrar aktifleştirildi."
                : "Proje kapatıldı.");
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast);
        }
    }

    private async Task DeselectAssignmentsAsync()
    {
        if (_assignmentsGrid is not null)
            await _assignmentsGrid.DeselectAllAsync();
    }

    private async Task ApproveSelectedRewardsAsync()
    {
        if (!_canManageRewards)
        {
            Toast.Error("Ödül onaylama yetkiniz yok.");
            return;
        }

        var ids = _selectedAssignments.Cast<ProjectAssignmentDto>()
            .Where(IsRewardPendingApproval)
            .Select(a => a.SubjectId)
            .ToList();

        if (ids.Count == 0)
        {
            Toast.Warning("Onaylanacak bekleyen kazanç bulunamadı.");
            return;
        }

        _isRewardProcessing = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            var result = await AssignmentService.ApproveRewardsAsync(ProjectId, ids, adminId);
            Toast.Success($"Onaylandı: {result.ProcessedCount} kayıt, {result.ProcessedAmount:N2} {_rewardUnitLabel}");
            if (result.SkippedCount > 0)
                Toast.Warning($"Atlandı: {result.SkippedCount} kayıt.");

            await LoadAssignmentsAsync();
            await DeselectAssignmentsAsync();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast);
        }
        finally
        {
            _isRewardProcessing = false;
        }
    }

    private void ShowRewardRejectPopup()
    {
        if (!_canManageRewards)
        {
            Toast.Error("Ödül reddetme yetkiniz yok.");
            return;
        }

        _rewardRejectTargetSubjectIds = _selectedAssignments.Cast<ProjectAssignmentDto>()
            .Where(IsRewardPendingApproval)
            .Select(a => a.SubjectId)
            .ToList();

        if (_rewardRejectTargetSubjectIds.Count == 0)
        {
            Toast.Warning("Reddedilecek bekleyen kazanç bulunamadı.");
            return;
        }

        _rewardRejectReason = string.Empty;
        _rewardRejectPopupVisible = true;
    }

    private async Task RejectSelectedRewardsAsync()
    {
        if (!_canManageRewards)
        {
            Toast.Error("Ödül reddetme yetkiniz yok.");
            return;
        }

        if (string.IsNullOrWhiteSpace(_rewardRejectReason))
        {
            Toast.Error("Red nedeni zorunludur.");
            return;
        }

        _rewardRejectPopupVisible = false;
        _isRewardProcessing = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            var result = await AssignmentService.RejectRewardsAsync(ProjectId, _rewardRejectTargetSubjectIds, _rewardRejectReason, adminId);
            Toast.Success($"Reddedildi: {result.ProcessedCount} kayıt, {result.ProcessedAmount:N2} {_rewardUnitLabel}");
            if (result.SkippedCount > 0)
                Toast.Warning($"Atlandı: {result.SkippedCount} kayıt.");

            await LoadAssignmentsAsync();
            await DeselectAssignmentsAsync();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast);
        }
        finally
        {
            _isRewardProcessing = false;
            _rewardRejectTargetSubjectIds = [];
            _rewardRejectReason = string.Empty;
        }
    }

    private void ShowBulkRemoveConfirm()
    {
        if (!_canManageSubjects)
        {
            Toast.Error("Denek çıkarma yetkiniz yok.");
            return;
        }

        _removeSubjectIds = _selectedAssignments.Cast<ProjectAssignmentDto>()
            .Where(a => a.Status is AssignmentStatus.NotStarted or AssignmentStatus.Scheduled)
            .Select(a => a.SubjectId)
            .Distinct()
            .ToList();

        if (_removeSubjectIds.Count == 0)
        {
            Toast.Warning("Projeden çıkarılabilecek (başlanmamış veya zamanlanmış) seçili denek yok.");
            return;
        }

        _assignmentToRemove = _removeSubjectIds.Count == 1
            ? _assignments.FirstOrDefault(a => a.SubjectId == _removeSubjectIds[0])
            : null;
        _removeConfirmVisible = true;
    }

    private void ShowRemoveConfirm(ProjectAssignmentDto assignment)
    {
        if (!_canManageSubjects)
        {
            Toast.Error("Denek çıkarma yetkiniz yok.");
            return;
        }

        _removeSubjectIds = [assignment.SubjectId];
        _assignmentToRemove = assignment;
        _removeConfirmVisible = true;
    }

    private async Task ConfirmRemoveAsync()
    {
        if (!_canManageSubjects)
        {
            Toast.Error("Denek çıkarma yetkiniz yok.");
            return;
        }

        if (_removeSubjectIds.Count == 0) return;
        _isRemoving = true;
        try
        {
            var adminId = await GetAdminIdAsync();
            var result = await AssignmentService.RemoveAssignmentsAsync(ProjectId, _removeSubjectIds, adminId);
            Toast.Warning($"Projeden çıkarıldı: {result.RemovedCount} kayıt.");
            if (result.SkippedCount > 0)
                Toast.Warning($"Atlandı: {result.SkippedCount} kayıt (başlamış veya bulunamadı).");

            _removeConfirmVisible = false;
            await LoadAssignmentsAsync();
            await DeselectAssignmentsAsync();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast);
        }
        finally
        {
            _isRemoving = false;
            _removeSubjectIds = [];
            _assignmentToRemove = null;
        }
    }

    private async Task<int> GetAdminIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim     = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        return claim is not null && int.TryParse(claim.Value, out var adminUserId)
            ? adminUserId
            : 0;
    }

    private static bool IsRewardPendingApproval(ProjectAssignmentDto assignment)
        => (assignment.Status is AssignmentStatus.Completed
            or AssignmentStatus.Disqualify
            or AssignmentStatus.QuotaFull
            or AssignmentStatus.ScreenOut)
           && assignment.RewardStatus is RewardStatus.Pending or RewardStatus.None;

