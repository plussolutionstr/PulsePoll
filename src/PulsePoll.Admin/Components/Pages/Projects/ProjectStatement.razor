@page "/projects/{ProjectId:int}/statement"
@attribute [HasPermission(PermissionCodes.Projects.StatementView)]
@using PulsePoll.Domain.Enums
@using PulsePoll.Application.Extensions
@using System.Security.Claims
@inject IProjectService ProjectService
@inject IAdminAssignmentService AssignmentService
@inject IAppToastService Toast
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Proje Ekstresi — PulsePoll Admin</PageTitle>

<div class="d-flex align-items-center justify-content-between gap-2 mb-3">
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <DxButton Text="← Projeler"
                  RenderStyle="ButtonRenderStyle.Link"
                  Click="@(() => Nav.NavigateTo("/projects"))" />
        <span class="text-muted">/</span>
        <span class="fw-semibold">@(_project?.Name ?? "Proje Ekstresi")</span>
        @if (_project is not null)
        {
            <span class="badge bg-secondary">@_project.Code</span>
        }
    </div>
    <div class="d-flex align-items-center gap-2">
        @if (_project is not null)
        {
            @if (_project.IsBilled)
            {
                <span class="badge bg-success-subtle text-success">
                    <i class="bi bi-check-circle me-1"></i>Faturalandı
                    @if (_project.BilledAt.HasValue)
                    {
                        <span class="ms-1 small">(@_project.BilledAt.Value.ToString("dd.MM.yyyy"))</span>
                    }
                </span>
                <DxButton Text="İşareti Kaldır"
                          IconCssClass="bi bi-x-circle"
                          RenderStyle="ButtonRenderStyle.Warning"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          SizeMode="SizeMode.Small"
                          Enabled="@(!_isBilling)"
                          Click="@(() => SetBilledAsync(false))" />
            }
            else
            {
                <DxButton Text="Faturalandı Olarak İşaretle"
                          IconCssClass="bi bi-receipt"
                          RenderStyle="ButtonRenderStyle.Success"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          SizeMode="SizeMode.Small"
                          Enabled="@(!_isBilling)"
                          Click="@(() => SetBilledAsync(true))" />
            }
        }
        <DxButton Text="Yenile"
                  IconCssClass="bi bi-arrow-clockwise"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  SizeMode="SizeMode.Small"
                  Click="LoadAsync" />
    </div>
</div>

<DxLoadingPanel @bind-Visible="_isLoading"
                IsContentBlocked="true"
                ApplyBackgroundShading="true"
                IndicatorAreaVisible="false"
                Text="Yükleniyor...">
    @if (_project is null)
    {
        <div class="alert alert-warning mb-0">Proje bulunamadı.</div>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Completed Hedefi</div>
                        <div class="h4 mb-0">@_project.TotalTargetCount.ToString("N0")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Faturalanabilir Completed</div>
                        <div class="h4 mb-0">@_invoiceAssignments.Count.ToString("N0")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Birim Fiyat</div>
                        <div class="h4 mb-0">@InvoiceUnitPrice.ToString("N2") TL</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">KDV Oranı</div>
                        <DxSpinEdit @bind-Value="_vatRate"
                                    MinValue="0m"
                                    MaxValue="100m"
                                    Increment="1m"
                                    DisplayFormat="N0"
                                    CssClass="w-100" />
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Fatura Ara Toplam</div>
                        <div class="h5 mb-0 text-primary">@InvoiceNet.ToString("N2") TL</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">KDV Tutarı</div>
                        <div class="h5 mb-0 text-primary">@VatAmount.ToString("N2") TL</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Fatura Toplamı</div>
                        <div class="h5 mb-0 text-primary">@InvoiceTotal.ToString("N2") TL</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-danger shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small">Onaylı Denek Maliyeti</div>
                        <div class="h5 mb-0 text-danger">@CostTotalTry.ToString("N2") TL</div>
                        <div class="small text-muted">@CostTotalUnit.ToString("N2") @RewardUnitLabel</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3 shadow-sm">
            <div class="card-body py-3 d-flex flex-wrap align-items-center gap-4">
                <div>
                    <div class="text-muted small">Proje Karlılığı (KDV Hariç)</div>
                    <div class="h4 mb-0 @(GrossProfit >= 0 ? "text-success" : "text-danger")">@GrossProfit.ToString("N2") TL</div>
                </div>
                <div>
                    <div class="text-muted small">Karlılık Oranı</div>
                    <div class="h5 mb-0">@ProfitMargin.ToString("N2")%</div>
                </div>
                <div class="text-muted small">
                    Formül: <strong>Fatura Ara Toplam - Onaylı Denek Maliyeti</strong>
                </div>
            </div>
        </div>

        <div class="card mb-3 shadow-sm">
            <div class="card-header fw-semibold">Faturaya Dahil Denekler (Completed + Ödül Onaylı)</div>
            <div class="card-body p-0">
                <DxGrid Data="@_invoiceRows"
                        ShowFilterRow="true"
                        PageSize="25">
                    <Columns>
                        <DxGridDataColumn FieldName="SubjectId" Caption="Denek Id" Width="90px" />
                        <DxGridDataColumn FieldName="FullName" Caption="Ad Soyad" />
                        <DxGridDataColumn FieldName="PhoneNumber" Caption="Telefon" Width="130px" />
                        <DxGridDataColumn FieldName="CompletedAt" Caption="Tamamlanma" DisplayFormat="dd.MM.yyyy HH:mm" Width="165px" />
                        <DxGridDataColumn FieldName="UnitPriceTry" Caption="Birim Fiyat (TL)" DisplayFormat="N2" Width="130px" />
                        <DxGridDataColumn FieldName="LineAmountTry" Caption="Fatura Tutarı (TL)" DisplayFormat="N2" Width="150px" />
                    </Columns>
                    <TotalSummary>
                        <DxGridSummaryItem SummaryType="GridSummaryItemType.Count"
                                           FieldName="SubjectId"
                                           FooterColumnName="SubjectId"
                                           DisplayText="Kayıt: {0}" />
                        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                                           FieldName="LineAmountTry"
                                           FooterColumnName="LineAmountTry"
                                           DisplayText="Toplam: {0:N2} TL" />
                    </TotalSummary>
                </DxGrid>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Onaylı Ödül Maliyeti (Tam + Teselli)</div>
            <div class="card-body p-0">
                <DxGrid Data="@_costRows"
                        ShowFilterRow="true"
                        PageSize="25">
                    <Columns>
                        <DxGridDataColumn FieldName="SubjectId" Caption="Denek Id" Width="90px" />
                        <DxGridDataColumn FieldName="FullName" Caption="Ad Soyad" />
                        <DxGridDataColumn FieldName="PhoneNumber" Caption="Telefon" Width="130px" />
                        <DxGridDataColumn FieldName="StatusLabel" Caption="Anket Durumu" Width="120px" />
                        <DxGridDataColumn FieldName="CompletedAt" Caption="Tamamlanma" DisplayFormat="dd.MM.yyyy HH:mm" Width="165px" />
                        <DxGridDataColumn FieldName="EarnedAmountUnit" Caption="@($"Ödül ({RewardUnitLabel})")" DisplayFormat="N2" Width="130px" />
                        <DxGridDataColumn FieldName="EarnedAmountTry" Caption="TL Karşılığı" DisplayFormat="N2" Width="120px" />
                    </Columns>
                    <TotalSummary>
                        <DxGridSummaryItem SummaryType="GridSummaryItemType.Count"
                                           FieldName="SubjectId"
                                           FooterColumnName="SubjectId"
                                           DisplayText="Kayıt: {0}" />
                        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                                           FieldName="EarnedAmountUnit"
                                           FooterColumnName="EarnedAmountUnit"
                                           DisplayText=@($"Toplam: {{0:N2}} {RewardUnitLabel}") />
                        <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum"
                                           FieldName="EarnedAmountTry"
                                           FooterColumnName="EarnedAmountTry"
                                           DisplayText="Toplam: {0:N2} TL" />
                    </TotalSummary>
                </DxGrid>
            </div>
        </div>
    }
</DxLoadingPanel>

@code {
    [Parameter] public int ProjectId { get; set; }

    private bool _isLoading = true;
    private ProjectDto? _project;
    private List<ProjectAssignmentDto> _assignments = [];
    private List<InvoiceRow> _invoiceRows = [];
    private List<CostRow> _costRows = [];
    private List<ProjectAssignmentDto> _invoiceAssignments = [];
    private List<ProjectAssignmentDto> _costAssignments = [];
    private decimal _vatRate = 20m;
    private bool _isBilling;

    private decimal InvoiceUnitPrice => _project?.Budget ?? 0m;
    private decimal InvoiceNet => _invoiceAssignments.Count * InvoiceUnitPrice;
    private decimal VatAmount => Math.Round(InvoiceNet * _vatRate / 100m, 2);
    private decimal InvoiceTotal => InvoiceNet + VatAmount;
    private decimal CostTotalUnit => _costAssignments.Sum(x => x.EarnedAmount);
    private decimal CostTotalTry => ToTry(CostTotalUnit);
    private decimal GrossProfit => InvoiceNet - CostTotalTry;
    private decimal ProfitMargin => InvoiceNet <= 0 ? 0 : Math.Round((GrossProfit / InvoiceNet) * 100m, 2);
    private string RewardUnitLabel => string.IsNullOrWhiteSpace(_project?.RewardUnitLabel) ? "TL" : _project!.RewardUnitLabel;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _project = await ProjectService.GetByIdAsync(ProjectId);
            if (_project is null)
            {
                _assignments = [];
                _invoiceRows = [];
                _costRows = [];
                return;
            }

            _assignments = await AssignmentService.GetAssignmentsAsync(ProjectId);
            Recalculate();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast, "Proje ekstresi yüklenemedi.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Recalculate()
    {
        _invoiceAssignments = _assignments
            .Where(x => x.Status == AssignmentStatus.Completed && x.RewardStatus == RewardStatus.Approved)
            .OrderByDescending(x => x.CompletedAt ?? x.AssignedAt)
            .ToList();

        _costAssignments = _assignments
            .Where(x => x.RewardStatus == RewardStatus.Approved && x.EarnedAmount > 0)
            .OrderByDescending(x => x.CompletedAt ?? x.AssignedAt)
            .ToList();

        _invoiceRows = _invoiceAssignments
            .Select(x => new InvoiceRow(
                x.SubjectId,
                x.FullName,
                x.PhoneNumber,
                x.CompletedAt,
                InvoiceUnitPrice,
                InvoiceUnitPrice))
            .ToList();

        _costRows = _costAssignments
            .Select(x => new CostRow(
                x.SubjectId,
                x.FullName,
                x.PhoneNumber,
                x.Status.GetDescription(),
                x.CompletedAt,
                x.EarnedAmount,
                ToTry(x.EarnedAmount)))
            .ToList();
    }

    private async Task SetBilledAsync(bool billed)
    {
        _isBilling = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
            var adminId = claim is not null && int.TryParse(claim.Value, out var id) ? id : 0;

            await ProjectService.SetBilledAsync(ProjectId, billed, adminId);
            Toast.Success(billed ? "Faturalandı olarak işaretlendi." : "Faturalandı işareti kaldırıldı.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ErrorHandler.HandleOperation(ex, Toast, "İşlem başarısız.");
        }
        finally
        {
            _isBilling = false;
        }
    }

    private decimal ToTry(decimal amount)
    {
        var multiplier = _project?.RewardUnitTryMultiplier ?? 1m;
        return Math.Round(amount * multiplier, 2);
    }

    private sealed record InvoiceRow(
        int SubjectId,
        string FullName,
        string PhoneNumber,
        DateTime? CompletedAt,
        decimal UnitPriceTry,
        decimal LineAmountTry);

    private sealed record CostRow(
        int SubjectId,
        string FullName,
        string PhoneNumber,
        string StatusLabel,
        DateTime? CompletedAt,
        decimal EarnedAmountUnit,
        decimal EarnedAmountTry);
}
