<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PulsePoll.Mobile.Controls.ConnectionErrorOverlay"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <VerticalStackLayout Spacing="16"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Padding="32">

        <Border StrokeThickness="0"
                StrokeShape="RoundRectangle 32"
                HeightRequest="64" WidthRequest="64"
                BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerLightDark}}"
                HorizontalOptions="Center">
            <Image Source="icon_info.png"
                   HeightRequest="28" WidthRequest="28"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <Label Text="Bağlantı Hatası"
               FontFamily="JakartaBold" FontSize="20"
               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
               HorizontalTextAlignment="Center"/>

        <Label Text="Sunucuya ulaşılamıyor. Lütfen internet bağlantınızı kontrol edip tekrar deneyin."
               FontFamily="JakartaRegular" FontSize="14"
               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,8"/>

        <Button x:Name="RetryButton"
                Text="Yeniden Dene"
                Style="{StaticResource PrimaryButtonStyle}"
                HorizontalOptions="Fill"
                Clicked="OnRetryClicked"/>

        <ActivityIndicator x:Name="RetrySpinner"
                           IsVisible="False"
                           IsRunning="False"
                           Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0"/>
    </VerticalStackLayout>
</ContentView>
