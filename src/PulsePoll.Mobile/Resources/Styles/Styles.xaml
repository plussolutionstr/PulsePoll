<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== Typography ===== -->
    <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaExtraBold"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="TitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaBold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="SubtitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaSemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="BodyStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
    </Style>

    <Style x:Key="CaptionStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaRegular"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource TextTertiary}"/>
    </Style>

    <!-- ===== Buttons ===== -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryPurple}"/>
        <Setter Property="TextColor" Value="{StaticResource White}"/>
        <Setter Property="FontFamily" Value="JakartaSemiBold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="CornerRadius" Value="26"/>
        <Setter Property="Padding" Value="24,0"/>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource White}"/>
        <Setter Property="TextColor" Value="{StaticResource PrimaryPurple}"/>
        <Setter Property="FontFamily" Value="JakartaSemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HeightRequest" Value="42"/>
        <Setter Property="CornerRadius" Value="21"/>
        <Setter Property="BorderColor" Value="{StaticResource CardBorder}"/>
        <Setter Property="BorderWidth" Value="1"/>
        <Setter Property="Padding" Value="20,0"/>
    </Style>

    <!-- ===== Card Border ===== -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource White}"/>
        <Setter Property="Stroke" Value="{StaticResource CardBorder}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 20"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ===== Default Styles ===== -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="JakartaRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="JakartaSemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryPurple}"/>
        <Setter Property="TextColor" Value="{StaticResource White}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="BorderWidth" Value="0"/>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="FontFamily" Value="JakartaRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource PrimaryPurple}"/>
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource PrimaryPurple}"/>
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource White}"/>
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource White}"/>
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource PrimaryPurple}"/>
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource PrimaryPurple}"/>
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextTertiary}"/>
        <Setter Property="Shell.NavBarHasShadow" Value="False"/>
        <Setter Property="Shell.DisabledColor" Value="{StaticResource TextTertiary}"/>
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource TextTertiary}"/>
    </Style>

</ResourceDictionary>
