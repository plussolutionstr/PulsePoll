<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== Primary ===== -->
    <Color x:Key="PrimaryPurple">#7C5CFC</Color>
    <Color x:Key="PrimaryPurpleDark">#9B82FF</Color>
    <Color x:Key="PrimaryLight">#EDE8FF</Color>
    <Color x:Key="PrimaryLightDark">#241E3D</Color>
    <Color x:Key="PrimaryMid">#C4B5FD</Color>
    <Color x:Key="PrimaryMidDark">#6B5CB8</Color>
    <Color x:Key="PrimaryDark">#5B3FD9</Color>
    <Color x:Key="PrimaryDarkDark">#7C5CFC</Color>

    <!-- ===== Semantic ===== -->
    <Color x:Key="Success">#22C988</Color>
    <Color x:Key="SuccessDark">#2DD4A0</Color>
    <Color x:Key="SuccessLight">#E6FBF4</Color>
    <Color x:Key="SuccessLightDark">#0D2E22</Color>
    <Color x:Key="Danger">#FF5C7A</Color>
    <Color x:Key="DangerDark">#FF6B8A</Color>
    <Color x:Key="DangerLight">#FFF0F3</Color>
    <Color x:Key="DangerLightDark">#2E0D15</Color>
    <Color x:Key="Amber">#F59E0B</Color>
    <Color x:Key="AmberDark">#FBBF24</Color>
    <Color x:Key="AmberLight">#FFFBEB</Color>
    <Color x:Key="AmberLightDark">#2E2510</Color>
    <Color x:Key="Blue">#3B82F6</Color>
    <Color x:Key="BlueDark">#60A5FA</Color>
    <Color x:Key="BlueLight">#EFF6FF</Color>
    <Color x:Key="BlueLightDark">#0D1A2E</Color>

    <!-- ===== Surfaces ===== -->
    <Color x:Key="PageBackground">#F7F5FF</Color>
    <Color x:Key="PageBackgroundDark">#0F0D1A</Color>
    <Color x:Key="SurfaceColor">#F0EDF9</Color>
    <Color x:Key="SurfaceColorDark">#282541</Color>
    <Color x:Key="CardBorder">#E8E3F5</Color>
    <Color x:Key="CardBorderDark">#2A2640</Color>

    <!-- ===== Text ===== -->
    <Color x:Key="TextPrimary">#1A1535</Color>
    <Color x:Key="TextPrimaryDark">#F0ECF7</Color>
    <Color x:Key="TextSecondary">#6B6589</Color>
    <Color x:Key="TextSecondaryDark">#9E95B0</Color>
    <Color x:Key="TextTertiary">#B0AABE</Color>
    <Color x:Key="TextTertiaryDark">#7A7490</Color>

    <!-- ===== Base ===== -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="WhiteDark">#1E1B2E</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Transparent">Transparent</Color>

    <!-- ===== Shimmer Skeleton ===== -->
    <Color x:Key="ShimmerLight">#ECE6F7</Color>
    <Color x:Key="ShimmerLightDark">#332E4D</Color>
    <Color x:Key="ShimmerBase">#E8E1F6</Color>
    <Color x:Key="ShimmerBaseDark">#2A2640</Color>
    <Color x:Key="ShimmerMid">#E4DDF2</Color>
    <Color x:Key="ShimmerMidDark">#252140</Color>
    <Color x:Key="ShimmerMuted">#DDD4F0</Color>
    <Color x:Key="ShimmerMutedDark">#201D38</Color>
    <Color x:Key="ShimmerDeep">#D8CEE9</Color>
    <Color x:Key="ShimmerDeepDark">#1C1933</Color>
    <Color x:Key="ShimmerCard">#C4B5E0</Color>
    <Color x:Key="ShimmerCardDark">#1A1730</Color>
    <Color x:Key="ShimmerPink">#F5E0E0</Color>
    <Color x:Key="ShimmerPinkDark">#2E1C1C</Color>
    <Color x:Key="ShimmerAmber">#F5E8C8</Color>
    <Color x:Key="ShimmerAmberDark">#2E2510</Color>
    <Color x:Key="ShimmerSweepHighlight">#66FFFFFF</Color>
    <Color x:Key="ShimmerSweepHighlightDark">#33FFFFFF</Color>

    <!-- ===== History Gradients ===== -->
    <Color x:Key="HistorySuccessStart">#E6FBF4</Color>
    <Color x:Key="HistorySuccessStartDark">#0D2E22</Color>
    <Color x:Key="HistorySuccessEnd">#C6F7E2</Color>
    <Color x:Key="HistorySuccessEndDark">#0A2519</Color>
    <Color x:Key="HistoryDangerStart">#FFF0F3</Color>
    <Color x:Key="HistoryDangerStartDark">#2E0D15</Color>
    <Color x:Key="HistoryDangerEnd">#FDDDE4</Color>
    <Color x:Key="HistoryDangerEndDark">#250A11</Color>
    <Color x:Key="HistoryPurpleEnd">#D4CBFF</Color>
    <Color x:Key="HistoryPurpleEndDark">#1D1835</Color>

    <!-- ===== Status Text (History) ===== -->
    <Color x:Key="SuccessText">#0D9668</Color>
    <Color x:Key="SuccessTextDark">#34D399</Color>
    <Color x:Key="DangerText">#D6336C</Color>
    <Color x:Key="DangerTextDark">#FB7185</Color>

    <!-- ===== Misc ===== -->
    <Color x:Key="AmberBorder">#FDE68A</Color>
    <Color x:Key="AmberBorderDark">#92710C</Color>

    <!-- ===== Legacy compat (Shell styles) ===== -->
    <Color x:Key="Primary">#7C5CFC</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="PrimaryPurpleBrush" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"/>

</ResourceDictionary>
