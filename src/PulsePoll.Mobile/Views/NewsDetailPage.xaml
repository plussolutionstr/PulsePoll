<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PulsePoll.Mobile.Views.NewsDetailPage"
             x:DataType="vm:NewsDetailViewModel"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <ScrollView.Triggers>
                <DataTrigger TargetType="ScrollView"
                             Binding="{Binding IsLoading}"
                             Value="True">
                    <Setter Property="IsVisible" Value="False"/>
                </DataTrigger>
            </ScrollView.Triggers>
            <VerticalStackLayout Spacing="14" Padding="20,16,20,22">
                <HorizontalStackLayout Spacing="8">
                    <ImageButton Source="icon_arrow_left.png"
                                 HeightRequest="24"
                                 WidthRequest="24"
                                 Command="{Binding GoBackCommand}">
                        <ImageButton.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                    <Label Text="Haber"
                           Style="{StaticResource TitleStyle}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Label Text="{Binding NewsItem.Title}"
                       FontFamily="JakartaExtraBold"
                       FontSize="24"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       LineHeight="1.2"/>

                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 18"
                        HeightRequest="220"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColor}, Dark={StaticResource SurfaceColorDark}}">
                    <Grid>
                        <Image Source="icon_star.png"
                               HeightRequest="56"
                               WidthRequest="56"
                               Opacity="0.2"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                        <Image Source="{Binding NewsItem.ImageUrl}"
                               Aspect="AspectFill"/>
                    </Grid>
                </Border>

                <Label Text="{Binding NewsItem.Subtitle}"
                       FontFamily="JakartaRegular"
                       FontSize="15"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       LineHeight="1.45"/>

                <Border IsVisible="{Binding HasLink}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                        Padding="14,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenLinkCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Habere Git"
                               FontFamily="JakartaBold"
                               FontSize="14"
                               TextColor="White"/>
                        <Label Text=">"
                               FontFamily="JakartaBold"
                               FontSize="14"
                               TextColor="White"/>
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- SHIMMER OVERLAY -->
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <VerticalStackLayout Spacing="14" Padding="20,16,20,22">
                    <!-- Header skeleton -->
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="24" WidthRequest="24"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="22" WidthRequest="60"
                                VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Title skeleton -->
                    <VerticalStackLayout Spacing="6">
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="26" HorizontalOptions="Fill"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="26" WidthRequest="200"
                                HorizontalOptions="Start"/>
                    </VerticalStackLayout>

                    <!-- Image skeleton -->
                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                            StrokeShape="RoundRectangle 18"
                            HeightRequest="220"/>

                    <!-- Body text skeletons -->
                    <VerticalStackLayout Spacing="8">
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="16" HorizontalOptions="Fill"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="16" HorizontalOptions="Fill"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="16" WidthRequest="240"
                                HorizontalOptions="Start"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="16" HorizontalOptions="Fill"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="16" WidthRequest="180"
                                HorizontalOptions="Start"/>
                    </VerticalStackLayout>

                    <!-- Button skeleton -->
                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                            StrokeShape="RoundRectangle 14"
                            HeightRequest="48" HorizontalOptions="Fill"/>
                </VerticalStackLayout>

                <!-- Shimmer Sweep -->
                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource ShimmerSweepHighlight}, Dark={StaticResource ShimmerSweepHighlightDark}}" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
