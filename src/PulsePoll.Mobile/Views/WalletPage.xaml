<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             xmlns:controls="clr-namespace:PulsePoll.Mobile.Controls"
             x:Class="PulsePoll.Mobile.Views.WalletPage"
             x:DataType="vm:WalletViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:AmountToColorConverter x:Key="AmountToColor"/>
    </ContentPage.Resources>

    <Grid>
        <!-- ══════ MAIN CONTENT ══════ -->
        <ScrollView x:Name="MainContent">
            <ScrollView.Triggers>
                <DataTrigger TargetType="ScrollView"
                             Binding="{Binding IsLoading}"
                             Value="True">
                    <Setter Property="IsVisible" Value="False"/>
                </DataTrigger>
            </ScrollView.Triggers>
            <VerticalStackLayout Spacing="16" Padding="20,16">

                <Label Text="Cüzdan" Style="{StaticResource PageTitleStyle}"/>

                <!-- Balance Card -->
                <Border x:Name="CoachBalanceCard"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24"
                        Padding="24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource PrimaryDarkDark}}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Çekilebilir Bakiye"
                                   FontFamily="JakartaRegular" FontSize="13"
                                   TextColor="#AAFFFFFF"/>
                            <Label Text="{Binding WithdrawableBalanceDisplay}"
                                   FontFamily="JakartaExtraBold" FontSize="32"
                                   TextColor="White"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Puan" FontFamily="JakartaRegular" FontSize="12" TextColor="#AAFFFFFF"/>
                                <Label Text="{Binding PointsDisplay}"
                                       FontFamily="JakartaBold" FontSize="16" TextColor="White"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Toplam Kazanç" FontFamily="JakartaRegular" FontSize="12" TextColor="#AAFFFFFF"/>
                                <Label Text="{Binding TotalEarnedDisplay}"
                                       FontFamily="JakartaBold" FontSize="16" TextColor="White"/>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid x:Name="CoachActionButtons" ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="Para Çek"
                                    FontFamily="JakartaSemiBold" FontSize="14"
                                    BackgroundColor="White"
                                    TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                    CornerRadius="22" HeightRequest="44"
                                    Command="{Binding NavigateToWithdrawCommand}"/>
                            <Button Grid.Column="1" Text="Geçmiş"
                                    FontFamily="JakartaSemiBold" FontSize="14"
                                    BackgroundColor="#30FFFFFF"
                                    TextColor="White"
                                    CornerRadius="22" HeightRequest="44"
                                    BorderWidth="0"
                                    Command="{Binding NavigateToHistoryCommand}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Bank Accounts -->
                <Label Text="Banka Hesapları"
                       Style="{StaticResource TitleStyle}" Margin="0,8,0,0"/>

                <VerticalStackLayout Spacing="8"
                                     BindableLayout.ItemsSource="{Binding BankAccounts}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:BankAccountModel">
                            <Border Style="{StaticResource CardBorderStyle}" Padding="14">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToEditBankAccountCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="12">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            HeightRequest="40" WidthRequest="56"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}">
                                        <Image Source="{Binding DisplayImageUrl}"
                                               HeightRequest="28"
                                               WidthRequest="48"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding BankName}"
                                               FontFamily="JakartaSemiBold" FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                        <Label Text="{Binding MaskedIban}"
                                               Style="{StaticResource CaptionStyle}"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button x:Name="CoachAddBankAccount" Text="+ Yeni Hesap Ekle"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalOptions="Fill"
                        Command="{Binding NavigateToAddBankAccountCommand}"/>

                <!-- Recent Transactions -->
                <Label Text="Son İşlemler"
                       Style="{StaticResource TitleStyle}" Margin="0,8,0,0"/>

                <VerticalStackLayout Spacing="8"
                                     BindableLayout.ItemsSource="{Binding RecentTransactions}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:TransactionModel">
                            <Border Style="{StaticResource CardBorderStyle}" Padding="14">
                                <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20"
                                            HeightRequest="40" WidthRequest="40"
                                            BackgroundColor="{Binding IconBgColor}">
                                        <Label Text="{Binding IconGlyph}"
                                               FontFamily="JakartaBold" FontSize="20"
                                               TextColor="{Binding IconColor}"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Title}"
                                               FontFamily="JakartaSemiBold" FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                        <Label Text="{Binding Description}"
                                               Style="{StaticResource CaptionStyle}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2"
                                           Text="{Binding AmountDisplay}"
                                           FontFamily="JakartaSemiBold" FontSize="14"
                                           TextColor="{Binding Amount, Converter={StaticResource AmountToColor}}"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <BoxView HeightRequest="20" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════ SHIMMER OVERLAY ══════ -->
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <ScrollView>
                    <VerticalStackLayout Spacing="16" Padding="20,16">
                        <!-- Title -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="26" WidthRequest="100"
                                HorizontalOptions="Start"/>

                        <!-- Balance Card -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerCard}, Dark={StaticResource ShimmerCardDark}}"
                                StrokeShape="RoundRectangle 24"
                                HeightRequest="210"/>

                        <!-- Bank Accounts Title -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="22" WidthRequest="140"
                                HorizontalOptions="Start" Margin="0,8,0,0"/>

                        <!-- Bank Account Rows -->
                        <VerticalStackLayout Spacing="8">
                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="68"/>
                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="68"/>
                        </VerticalStackLayout>

                        <!-- Add Button -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 14"
                                HeightRequest="44"/>

                        <!-- Transactions Title -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="22" WidthRequest="120"
                                HorizontalOptions="Start" Margin="0,8,0,0"/>

                        <!-- Transaction Rows -->
                        <VerticalStackLayout Spacing="8">
                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="68"/>
                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="68"/>
                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="68"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Shimmer Sweep -->
                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource ShimmerSweepHighlight}, Dark={StaticResource ShimmerSweepHighlightDark}}" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
        <controls:CoachMarkOverlay x:Name="CoachMark" Key="wallet"/>
    </Grid>
</ContentPage>
