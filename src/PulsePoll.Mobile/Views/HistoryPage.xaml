<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:StatusToBgColorConverter x:Key="StatusToBgColor"/>
        <converters:StatusToIconConverter x:Key="StatusToIcon"/>
    </ContentPage.Resources>

    <Grid>
    <ScrollView>
        <ScrollView.Triggers>
            <DataTrigger TargetType="ScrollView"
                         Binding="{Binding IsLoading}"
                         Value="True">
                <Setter Property="IsVisible" Value="False"/>
            </DataTrigger>
        </ScrollView.Triggers>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <Label Text="Geçmiş" Style="{StaticResource PageTitleStyle}"/>

            <!-- Summary Boxes -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <!-- Tamamlanan -->
                <Border StrokeShape="RoundRectangle 18" StrokeThickness="0" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light={StaticResource HistorySuccessStart}, Dark={StaticResource HistorySuccessStartDark}}" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource HistorySuccessEnd}, Dark={StaticResource HistorySuccessEndDark}}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2" Padding="12,14">
                        <Label Text="&#x2713;"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource SuccessDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding CompletedCount}"
                               FontFamily="JakartaBold" FontSize="24"
                               TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Tamamlanan" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Elenen -->
                <Border Grid.Column="1" StrokeShape="RoundRectangle 18" StrokeThickness="0" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light={StaticResource HistoryDangerStart}, Dark={StaticResource HistoryDangerStartDark}}" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource HistoryDangerEnd}, Dark={StaticResource HistoryDangerEndDark}}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2" Padding="12,14">
                        <Label Text="&#x2717;"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding DisqualifiedCount}"
                               FontFamily="JakartaBold" FontSize="24"
                               TextColor="{AppThemeBinding Light={StaticResource DangerText}, Dark={StaticResource DangerTextDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Elenen" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource DangerText}, Dark={StaticResource DangerTextDark}}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Toplam Kazanç -->
                <Border Grid.Column="2" StrokeShape="RoundRectangle 18" StrokeThickness="0" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource HistoryPurpleEnd}, Dark={StaticResource HistoryPurpleEndDark}}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2" Padding="12,14">
                        <Label Text="&#x2605;"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding TotalEarnedDisplay}"
                               FontFamily="JakartaBold" FontSize="24"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource PrimaryDarkDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Toplam" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource PrimaryDarkDark}}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Filter Tabs -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8"
                                       BindableLayout.ItemsSource="{Binding Filters}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColor}, Dark={StaticResource SurfaceColorDark}}"
                                    Padding="16,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=SetFilterCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}"
                                       FontFamily="JakartaSemiBold" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Empty State -->
            <VerticalStackLayout IsVisible="{Binding IsListEmpty}"
                                 Spacing="12"
                                 Padding="0,24"
                                 HorizontalOptions="Center">
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 32"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                        HeightRequest="64" WidthRequest="64"
                        HorizontalOptions="Center">
                    <Label Text="&#x1F50D;"
                           FontSize="28"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Label Text="Burada henüz bir şey yok"
                       FontFamily="JakartaSemiBold"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Anketlere katıldıkça geçmişin burada görünecek."
                       FontFamily="JakartaRegular"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- History Items -->
            <VerticalStackLayout Spacing="8"
                                 BindableLayout.ItemsSource="{Binding FlatItems}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:HistoryItemModel">
                        <Border Style="{StaticResource CardBorderStyle}" Padding="14">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <!-- Info -->
                                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding SurveyTitle}"
                                           FontFamily="JakartaSemiBold" FontSize="14"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           MaxLines="1" LineBreakMode="TailTruncation"/>
                                    <HorizontalStackLayout Spacing="6">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColor}, Dark={StaticResource SurfaceColorDark}}"
                                                Padding="6,2">
                                            <Label Text="{Binding DurationMinutes, StringFormat='~{0} dk'}"
                                                   FontFamily="JakartaMedium" FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                        </Border>
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource SuccessLight}, Dark={StaticResource SuccessLightDark}}"
                                                Padding="6,2">
                                            <Label Text="{Binding RewardAmountDisplay}"
                                                   FontFamily="JakartaMedium" FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource SuccessDark}}"/>
                                        </Border>
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource AmberLight}, Dark={StaticResource AmberLightDark}}"
                                                Padding="6,2">
                                            <Label Text="{Binding ConsolationAmountDisplay}"
                                                   FontFamily="JakartaMedium" FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource Amber}, Dark={StaticResource AmberDark}}"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Date, StringFormat='{0:dd MMM yyyy}'}"
                                           FontFamily="JakartaRegular" FontSize="11"
                                           TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource TextTertiaryDark}}"/>
                                </VerticalStackLayout>

                                <!-- Status Badge -->
                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{Binding Status, Converter={StaticResource StatusToBgColor}}"
                                        Padding="10,4"
                                        VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                               FontFamily="JakartaBold" FontSize="11"
                                               TextColor="{Binding Status, Converter={StaticResource StatusToColor}}"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding Status}"
                                               FontFamily="JakartaSemiBold" FontSize="12"
                                               TextColor="{Binding Status, Converter={StaticResource StatusToColor}}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <BoxView HeightRequest="20" Color="Transparent"/>
        </VerticalStackLayout>
    </ScrollView>
        <!-- SHIMMER OVERLAY -->
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <VerticalStackLayout Spacing="16" Padding="20,16">
                    <!-- Title skeleton -->
                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                            StrokeShape="RoundRectangle 8"
                            HeightRequest="28" WidthRequest="120"
                            HorizontalOptions="Start"/>

                    <!-- Summary boxes skeleton -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 18"
                                HeightRequest="100"/>
                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 18"
                                HeightRequest="100"/>
                        <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 18"
                                HeightRequest="100"/>
                    </Grid>

                    <!-- Filter tabs skeleton -->
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="34" WidthRequest="60"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="34" WidthRequest="90"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="34" WidthRequest="70"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="34" WidthRequest="80"/>
                    </HorizontalStackLayout>

                    <!-- History item skeletons -->
                    <VerticalStackLayout Spacing="8">
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 16" HeightRequest="76"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 16" HeightRequest="76"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 16" HeightRequest="76"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 16" HeightRequest="76"/>
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 16" HeightRequest="76"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Shimmer Sweep -->
                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource ShimmerSweepHighlight}, Dark={StaticResource ShimmerSweepHighlightDark}}" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
