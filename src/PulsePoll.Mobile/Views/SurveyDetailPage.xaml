<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             x:Class="PulsePoll.Mobile.Views.SurveyDetailPage"
             x:DataType="vm:SurveyDetailViewModel"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <ScrollView.Triggers>
                <DataTrigger TargetType="ScrollView"
                             Binding="{Binding IsLoading}"
                             Value="True">
                    <Setter Property="IsVisible" Value="False"/>
                </DataTrigger>
            </ScrollView.Triggers>
            <VerticalStackLayout Spacing="16" Padding="20,16,20,22">
                <HorizontalStackLayout Spacing="8">
                    <ImageButton Source="icon_arrow_left.png"
                                 HeightRequest="24"
                                 WidthRequest="24"
                                 Command="{Binding GoBackCommand}"/>
                    <Label Text="Anket Detayı"
                           Style="{StaticResource TitleStyle}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        MinimumHeightRequest="168"
                        BackgroundColor="{StaticResource PrimaryLight}"
                        Padding="18,16">
                    <Grid>
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 60"
                                HeightRequest="120"
                                WidthRequest="120"
                                BackgroundColor="#147C5CFC"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="0,-26,-22,0"/>
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 48"
                                HeightRequest="92"
                                WidthRequest="92"
                                BackgroundColor="#0E7C5CFC"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="0,0,0,-26"/>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Survey.Title}"
                                   FontFamily="JakartaExtraBold"
                                   FontSize="22"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="{Binding Survey.Description}"
                                   FontFamily="JakartaRegular"
                                   FontSize="14"
                                   LineHeight="1.4"
                                   IsVisible="{Binding Survey.HasDescription}"
                                   TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource CardBorder}"
                            BackgroundColor="{StaticResource White}"
                            Padding="12,14">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="icon_clock.png" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center"/>
                            <Label Text="{Binding Survey.DurationMinutes, StringFormat='~{0} dk'}"
                                   FontFamily="JakartaBold" FontSize="14"
                                   HorizontalTextAlignment="Center" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Süre"
                                   Style="{StaticResource CaptionStyle}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource CardBorder}"
                            BackgroundColor="{StaticResource White}"
                            Padding="12,14">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="icon_money.png" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center"/>
                            <Label Text="{Binding Survey.ConsolationRewardDisplay}"
                                   FontFamily="JakartaBold" FontSize="14"
                                   HorizontalTextAlignment="Center" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Teselli Ödülü"
                                   Style="{StaticResource CaptionStyle}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource CardBorder}"
                            BackgroundColor="{StaticResource White}"
                            Padding="12,14">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="icon_check.png" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center"/>
                            <Label Text="{Binding Survey.RewardDisplay}"
                                   FontFamily="JakartaBold" FontSize="14"
                                   HorizontalTextAlignment="Center" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="Ödül"
                                   Style="{StaticResource CaptionStyle}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Başlamadan Önce"
                               FontFamily="JakartaSemiBold"
                               FontSize="16"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="{Binding Survey.StartMessageDisplay}"
                               FontFamily="JakartaRegular"
                               FontSize="14"
                               LineHeight="1.45"
                               TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Ankete Başla"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartSurveyCommand}"
                        HorizontalOptions="Fill">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsStarting}"
                                     Value="True">
                            <Setter Property="Text" Value="Anket Açılıyor..."/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Label Text="Anket uygulama içinde güvenli tarayıcıda açılacaktır."
                       Style="{StaticResource CaptionStyle}"
                       HorizontalTextAlignment="Center"
                       Margin="20,0"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- SHIMMER OVERLAY -->
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{StaticResource PageBackground}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <VerticalStackLayout Spacing="16" Padding="20,16,20,22">
                    <!-- Header skeleton -->
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0" BackgroundColor="#E4DDF2"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="24" WidthRequest="24"/>
                        <Border StrokeThickness="0" BackgroundColor="#E4DDF2"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="22" WidthRequest="100"
                                VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Hero card skeleton -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            MinimumHeightRequest="168"
                            Padding="18,16">
                        <VerticalStackLayout Spacing="8">
                            <Border StrokeThickness="0" BackgroundColor="#D5CBF5"
                                    StrokeShape="RoundRectangle 8"
                                    HeightRequest="24" WidthRequest="220"
                                    HorizontalOptions="Start"/>
                            <Border StrokeThickness="0" BackgroundColor="#D5CBF5"
                                    StrokeShape="RoundRectangle 8"
                                    HeightRequest="24" WidthRequest="160"
                                    HorizontalOptions="Start"/>
                            <Border StrokeThickness="0" BackgroundColor="#DDD5F7"
                                    StrokeShape="RoundRectangle 6"
                                    HeightRequest="16" HorizontalOptions="Fill"
                                    Margin="0,4,0,0"/>
                            <Border StrokeThickness="0" BackgroundColor="#DDD5F7"
                                    StrokeShape="RoundRectangle 6"
                                    HeightRequest="16" WidthRequest="200"
                                    HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Info cards skeleton -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="90"/>
                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="90"/>
                        <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="90"/>
                    </Grid>

                    <!-- "Baslamadan Once" card skeleton -->
                    <Border StrokeThickness="0" BackgroundColor="#E8E1F6"
                            StrokeShape="RoundRectangle 16"
                            HeightRequest="100" HorizontalOptions="Fill"/>

                    <!-- Button skeleton -->
                    <Border StrokeThickness="0" BackgroundColor="#E4DDF2"
                            StrokeShape="RoundRectangle 14"
                            HeightRequest="50" HorizontalOptions="Fill"/>

                    <!-- Caption skeleton -->
                    <Border StrokeThickness="0" BackgroundColor="#ECE6F7"
                            StrokeShape="RoundRectangle 6"
                            HeightRequest="14" WidthRequest="280"
                            HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Shimmer Sweep -->
                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#66FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
