<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PulsePoll.Mobile.Views.HomePageClassic"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- Top Bar -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <Label Text="PulsePoll"
                       Style="{StaticResource PageTitleStyle}"
                       FontSize="24"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                       VerticalOptions="Center"/>
                <ImageButton Grid.Column="1"
                             Source="icon_bell.png"
                             HeightRequest="24" WidthRequest="24"
                             Command="{Binding NavigateToNotificationsCommand}"
                             VerticalOptions="Center">
                    <ImageButton.Behaviors>
                        <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    </ImageButton.Behaviors>
                </ImageButton>
            </Grid>

            <!-- Stories -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="16"
                                       BindableLayout.ItemsSource="{Binding Stories}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:StoryModel">
                            <VerticalStackLayout Spacing="6" WidthRequest="68">
                                <Border StrokeThickness="3"
                                        Stroke="{Binding RingStroke}"
                                        StrokeShape="RoundRectangle 32"
                                        HeightRequest="64" WidthRequest="64"
                                        HorizontalOptions="Center"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                        Padding="2">
                                    <Label Text="{Binding Title, StringFormat='{0:0}'}"
                                           FontFamily="JakartaBold"
                                           FontSize="11"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                           HorizontalTextAlignment="Center"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                </Border>
                                <Label Text="{Binding Title}"
                                       Style="{StaticResource CaptionStyle}"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Featured News -->
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="models:NewsModel"/>
            </BindableLayout.ItemTemplate>

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding News}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:NewsModel">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="20"
                                HeightRequest="140">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=OpenNewsCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}" Offset="0"/>
                                    <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource PrimaryDarkDark}}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="#50FFFFFF"
                                        Padding="8,4"
                                        HorizontalOptions="Start">
                                    <Label Text="{Binding Tag}"
                                           FontFamily="JakartaSemiBold"
                                           FontSize="11"
                                           TextColor="White"/>
                                </Border>
                                <Label Text="{Binding Title}"
                                       FontFamily="JakartaBold"
                                       FontSize="18"
                                       TextColor="White"/>
                                <Label Text="{Binding Subtitle}"
                                       FontFamily="JakartaRegular"
                                       FontSize="13"
                                       TextColor="#CCFFFFFF"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Sana Özel Header -->
            <Label Text="Sana Özel Anketler"
                   Style="{StaticResource TitleStyle}"
                   Margin="0,4,0,0"/>

            <!-- Survey Cards -->
            <VerticalStackLayout Spacing="12"
                                 BindableLayout.ItemsSource="{Binding Surveys}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:SurveyModel">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToSurveyDetailCommand}"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="10">
                                <!-- Brand Row -->
                                <Grid ColumnDefinitions="36,*,Auto">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18"
                                            HeightRequest="36" WidthRequest="36"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                        <Label Text="{Binding BrandName, StringFormat='{0:0}'}"
                                               FontFamily="JakartaBold" FontSize="12"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                               MaxLines="1"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" VerticalOptions="Center">
                                        <Label Text="{Binding BrandName}"
                                               Style="{StaticResource SubtitleStyle}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="2"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource AmberLight}, Dark={StaticResource AmberLightDark}}"
                                            Padding="10,4">
                                        <Label Text="{Binding RewardDisplay}"
                                               FontFamily="JakartaBold" FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    </Border>
                                </Grid>

                                <!-- Title -->
                                <Label Text="{Binding Title}"
                                       FontFamily="JakartaBold" FontSize="15"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>

                                <!-- Meta -->
                                <HorizontalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="4">
                                        <Image Source="icon_clock.png" HeightRequest="14" WidthRequest="14"
                                               VerticalOptions="Center">
                                            <Image.Behaviors>
                                                <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                            </Image.Behaviors>
                                        </Image>
                                        <Label Text="{Binding DurationMinutes, StringFormat='~{0} dk'}"
                                               Style="{StaticResource CaptionStyle}" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4">
                                        <Image Source="icon_check.png" HeightRequest="14" WidthRequest="14"
                                               VerticalOptions="Center">
                                            <Image.Behaviors>
                                                <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                            </Image.Behaviors>
                                        </Image>
                                        <Label Text="{Binding QuestionCount, StringFormat='{0} soru'}"
                                               Style="{StaticResource CaptionStyle}" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Category Tag -->
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                        Padding="10,4"
                                        IsVisible="{Binding HasCategory}"
                                        HorizontalOptions="Start">
                                    <Label Text="{Binding Category}"
                                           FontFamily="JakartaMedium" FontSize="11"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Bottom spacing for TabBar -->
            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
