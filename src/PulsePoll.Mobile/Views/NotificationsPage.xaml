<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.NotificationsPage"
             x:Name="NotificationsPageRoot"
             x:DataType="vm:NotificationsViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:NotificationTypeToBgConverter x:Key="TypeToBg"/>
        <converters:NotificationTypeToIconConverter x:Key="TypeToIcon"/>
        <converters:BoolToReadBgConverter x:Key="BoolToReadBg"/>
        <converters:InvertedBoolConverter x:Key="InvertedBool"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Header + Filters -->
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*,Auto">
                <ImageButton Source="icon_arrow_left.png"
                             HeightRequest="24" WidthRequest="24"
                             Command="{Binding GoBackCommand}"
                             VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="Bildirimler"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalOptions="Center"
                       Margin="12,0,0,0"/>
                <Label Grid.Column="2" Text="Tümünü Okundu İşaretle"
                       FontFamily="JakartaSemiBold" FontSize="12"
                       TextColor="{StaticResource PrimaryPurple}"
                       VerticalOptions="Center"
                       IsEnabled="{Binding CanMarkAllRead}"
                       Opacity="1">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding CanMarkAllRead}"
                                     Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </DataTrigger>
                    </Label.Triggers>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MarkAllReadCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Filter Tabs -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8"
                                       BindableLayout.ItemsSource="{Binding Filters}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{StaticResource SurfaceColor}"
                                    Padding="16,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=SetFilterCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}"
                                       FontFamily="JakartaSemiBold" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding ShowEmptyState}"
                             Spacing="8"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="20">
            <Label Text="Bildirim bulunamadı"
                   FontFamily="JakartaSemiBold"
                   FontSize="16"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Yeni bildirimler geldiğinde burada listelenecek."
                   Style="{StaticResource CaptionStyle}"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Notifications CollectionView -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Notifications}"
                        IsVisible="{Binding HasNotifications}"
                        SelectionMode="None"
                        Margin="20,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NotificationModel">
                    <SwipeView Margin="0,4"
                               Threshold="64">
                        <!-- Swipe Right: Mark as Read -->
                        <SwipeView.LeftItems>
                            <SwipeItems Mode="Reveal" SwipeBehaviorOnInvoked="Close">
                                <SwipeItem Text="Okundu"
                                           IconImageSource="icon_check.png"
                                           BackgroundColor="{StaticResource Success}"
                                           Command="{Binding Source={x:Reference NotificationsPageRoot}, Path=BindingContext.MarkOneReadCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <!-- Swipe Left: Delete -->
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal" SwipeBehaviorOnInvoked="Close">
                                <SwipeItem Text="Sil"
                                           IconImageSource="icon_x_circle.png"
                                           BackgroundColor="{StaticResource Danger}"
                                           Command="{Binding Source={x:Reference NotificationsPageRoot}, Path=BindingContext.DeleteNotificationCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- Notification Card -->
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="{StaticResource CardBorder}"
                                BackgroundColor="{Binding IsRead, Converter={StaticResource BoolToReadBg}}"
                                Padding="13">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=ShowNotificationCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="11">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14"
                                        HeightRequest="36" WidthRequest="36"
                                        BackgroundColor="{Binding Type, Converter={StaticResource TypeToBg}}">
                                    <Image Source="{Binding Type, Converter={StaticResource TypeToIcon}}"
                                           HeightRequest="14" WidthRequest="14"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 3"
                                                HeightRequest="6" WidthRequest="6"
                                                BackgroundColor="{StaticResource PrimaryPurple}"
                                                IsVisible="{Binding IsRead, Converter={StaticResource InvertedBool}}"
                                                VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontFamily="JakartaSemiBold" FontSize="13"
                                               TextColor="{StaticResource TextPrimary}"/>
                                    </Grid>
                                    <Label Text="{Binding Message}"
                                           Style="{StaticResource CaptionStyle}"
                                           TextColor="{StaticResource TextSecondary}"
                                           MaxLines="2" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="{Binding Date, StringFormat='{0:HH:mm}'}"
                                       Style="{StaticResource CaptionStyle}"
                                       VerticalOptions="Start"/>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.RowSpan="2"
                           IsVisible="{Binding IsLoading}"
                           IsRunning="{Binding IsLoading}"
                           Color="{StaticResource PrimaryPurple}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <!-- Popup Overlay -->
        <Grid Grid.RowSpan="2"
              IsVisible="{Binding IsPopupVisible}"
              BackgroundColor="#80000000"
              x:DataType="vm:NotificationsViewModel">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ClosePopupCommand}"/>
            </Grid.GestureRecognizers>

            <Border StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="24"
                    Margin="24"
                    VerticalOptions="Center"
                    HorizontalOptions="Fill"
                    x:DataType="vm:NotificationsViewModel">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="16"
                                     BindingContext="{Binding SelectedNotification}">
                    <Grid ColumnDefinitions="*,Auto"
                          x:DataType="models:NotificationModel">
                        <Label Text="{Binding Title}"
                               FontFamily="JakartaBold" FontSize="18"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding Date, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                               Style="{StaticResource CaptionStyle}"
                               VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource CardBorder}"/>
                    <Label x:DataType="models:NotificationModel"
                           Text="{Binding Message}"
                           FontFamily="JakartaRegular" FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           LineBreakMode="WordWrap"/>
                    <Button Text="Kapat"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HeightRequest="44"
                            HorizontalOptions="Fill"
                            x:DataType="vm:NotificationsViewModel"
                            BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext}"
                            Command="{Binding ClosePopupCommand}"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
