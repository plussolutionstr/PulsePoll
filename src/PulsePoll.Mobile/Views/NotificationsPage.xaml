<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.NotificationsPage"
             x:Name="NotificationsPageRoot"
             x:DataType="vm:NotificationsViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:NotificationTypeToBgConverter x:Key="TypeToBg"/>
        <converters:NotificationTypeToIconConverter x:Key="TypeToIcon"/>
        <converters:BoolToReadBgConverter x:Key="BoolToReadBg"/>
        <converters:InvertedBoolConverter x:Key="InvertedBool"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header + Filters -->
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*,Auto">
                <ImageButton Source="icon_arrow_left.png"
                             HeightRequest="24" WidthRequest="24"
                             Command="{Binding GoBackCommand}"
                             VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="Bildirimler"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalOptions="Center"
                       Margin="12,0,0,0"/>
                <Label Grid.Column="2"
                       Text="{Binding EditButtonText}"
                       FontFamily="JakartaSemiBold" FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                       VerticalOptions="Center"
                       IsVisible="{Binding HasNotifications}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleEditModeCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Filter Tabs -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8"
                                       BindableLayout.ItemsSource="{Binding Filters}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColor}, Dark={StaticResource SurfaceColorDark}}"
                                    Padding="16,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=SetFilterCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}"
                                       FontFamily="JakartaSemiBold" FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding ShowEmptyState}"
                             Spacing="8"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Padding="20">
            <Label Text="Bildirim bulunamadı"
                   FontFamily="JakartaSemiBold"
                   FontSize="16"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Yeni bildirimler geldiğinde burada listelenecek."
                   Style="{StaticResource CaptionStyle}"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Notifications CollectionView -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Notifications}"
                        IsVisible="{Binding HasNotifications}"
                        SelectionMode="None"
                        Margin="20,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:SelectableNotification">
                    <!-- Notification Card -->
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                            BackgroundColor="{Binding Model.IsRead, Converter={StaticResource BoolToReadBg}}"
                            Padding="13"
                            Margin="0,4">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsSelected}"
                                         Value="True">
                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                <Setter Property="StrokeThickness" Value="1.5"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=ShowNotificationCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,36,*,Auto" ColumnSpacing="11">
                            <!-- Checkbox (edit mode only) -->
                            <Border StrokeShape="RoundRectangle 4"
                                    StrokeThickness="1.5"
                                    Stroke="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                    HeightRequest="22" WidthRequest="22"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=IsEditMode}">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsSelected}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="&#x2713;"
                                       FontSize="13"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding IsSelected}"/>
                            </Border>

                            <!-- Type Icon -->
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    HeightRequest="36" WidthRequest="36"
                                    BackgroundColor="{Binding Model.Type, Converter={StaticResource TypeToBg}}">
                                <Image Source="{Binding Model.Type, Converter={StaticResource TypeToIcon}}"
                                       HeightRequest="14" WidthRequest="14"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <!-- Content -->
                            <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            HeightRequest="6" WidthRequest="6"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                            IsVisible="{Binding Model.IsRead, Converter={StaticResource InvertedBool}}"
                                            VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding Model.Title}"
                                           FontFamily="JakartaSemiBold" FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                </Grid>
                                <Label Text="{Binding Model.Message}"
                                       Style="{StaticResource CaptionStyle}"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       MaxLines="2" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- Time -->
                            <Label Grid.Column="3"
                                   Text="{Binding Model.Date, StringFormat='{0:HH:mm}'}"
                                   Style="{StaticResource CaptionStyle}"
                                   VerticalOptions="Start"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.RowSpan="2"
                           IsVisible="{Binding IsLoading}"
                           IsRunning="{Binding IsLoading}"
                           Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

        <!-- Bottom Action Bar (edit mode) -->
        <Border Grid.Row="2"
                IsVisible="{Binding IsEditMode}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0"
                BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
                Padding="20,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Label Text="{Binding SelectAllButtonText}"
                       FontFamily="JakartaSemiBold" FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleSelectAllCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
                <Button Grid.Column="2"
                        Text="Okundu"
                        FontFamily="JakartaSemiBold" FontSize="13"
                        TextColor="White"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource SuccessDark}}"
                        CornerRadius="20"
                        HeightRequest="40"
                        Padding="16,0"
                        Command="{Binding MarkSelectedReadCommand}"
                        IsEnabled="{Binding HasSelection}"
                        Opacity="1">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding HasSelection}"
                                     Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="3"
                        Text="Sil"
                        FontFamily="JakartaSemiBold" FontSize="13"
                        TextColor="White"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                        CornerRadius="20"
                        HeightRequest="40"
                        Padding="16,0"
                        Command="{Binding DeleteSelectedCommand}"
                        IsEnabled="{Binding HasSelection}"
                        Opacity="1">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding HasSelection}"
                                     Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </Border>

        <!-- Popup Overlay -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsPopupVisible}"
              BackgroundColor="#80000000"
              x:DataType="vm:NotificationsViewModel">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ClosePopupCommand}"/>
            </Grid.GestureRecognizers>

            <Border StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                    Padding="24"
                    Margin="24"
                    VerticalOptions="Center"
                    HorizontalOptions="Fill"
                    x:DataType="vm:NotificationsViewModel">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="16"
                                     BindingContext="{Binding SelectedNotification}">
                    <Grid ColumnDefinitions="*,Auto"
                          x:DataType="models:NotificationModel">
                        <Label Text="{Binding Title}"
                               FontFamily="JakartaBold" FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding Date, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                               Style="{StaticResource CaptionStyle}"
                               VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"/>
                    <Label x:DataType="models:NotificationModel"
                           Text="{Binding Message}"
                           FontFamily="JakartaRegular" FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           LineBreakMode="WordWrap"/>
                    <Button Text="Kapat"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HeightRequest="44"
                            HorizontalOptions="Fill"
                            x:DataType="vm:NotificationsViewModel"
                            BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext}"
                            Command="{Binding ClosePopupCommand}"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
