<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.WalletTransactionsPage"
             x:DataType="viewModels:WalletTransactionsViewModel"
             Title="İşlem Geçmişi">

    <ContentPage.Resources>
        <converters:AmountToColorConverter x:Key="AmountToColor"/>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="Auto,*">
            <Grid.Triggers>
                <DataTrigger TargetType="Grid"
                             Binding="{Binding IsLoading}"
                             Value="True">
                    <Setter Property="IsVisible" Value="False"/>
                </DataTrigger>
            </Grid.Triggers>

            <VerticalStackLayout Padding="20,16,20,10" Spacing="6">
                <Label Text="İşlem Geçmişi"
                       FontFamily="JakartaBold"
                       FontSize="24"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="Tüm cüzdan işlemleri"
                       FontFamily="JakartaRegular"
                       FontSize="13"
                       TextColor="{StaticResource TextTertiary}" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Transactions}"
                            RemainingItemsThreshold="3"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
                <CollectionView.EmptyView>
                    <Label Text="Henüz işlem yok."
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontFamily="JakartaRegular"
                           FontSize="14"
                           TextColor="{StaticResource TextTertiary}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TransactionModel">
                        <Border Margin="20,6"
                                Style="{StaticResource CardBorderStyle}"
                                Padding="14">
                            <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20"
                                        HeightRequest="40" WidthRequest="40"
                                        BackgroundColor="{Binding IconBgColor}">
                                    <Label Text="{Binding IconGlyph}"
                                           FontFamily="JakartaBold" FontSize="20"
                                           TextColor="{Binding IconColor}"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontFamily="JakartaSemiBold"
                                           FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    <Label Text="{Binding Description}"
                                           Style="{StaticResource CaptionStyle}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="{Binding AmountDisplay}"
                                       FontFamily="JakartaSemiBold"
                                       FontSize="14"
                                       TextColor="{Binding Amount, Converter={StaticResource AmountToColor}}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator Grid.RowSpan="2"
                               IsRunning="{Binding IsLoadingMore}"
                               IsVisible="{Binding IsLoadingMore}"
                               HorizontalOptions="Center"
                               VerticalOptions="End"
                               Margin="0,0,0,20" />
        </Grid>

        <!-- ══════ SHIMMER OVERLAY ══════ -->
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{StaticResource PageBackground}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <VerticalStackLayout Spacing="0">
                    <!-- Header -->
                    <VerticalStackLayout Padding="20,16,20,10" Spacing="6">
                        <Border StrokeThickness="0" BackgroundColor="#E4DDF2"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="26" WidthRequest="160"
                                HorizontalOptions="Start"/>
                        <Border StrokeThickness="0" BackgroundColor="#ECE6F7"
                                StrokeShape="RoundRectangle 6"
                                HeightRequest="15" WidthRequest="140"
                                HorizontalOptions="Start"/>
                    </VerticalStackLayout>

                    <!-- Transaction Row Skeletons -->
                    <VerticalStackLayout Spacing="0" Padding="0,6">
                        <Border Margin="20,6" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16" HeightRequest="68"/>
                        <Border Margin="20,6" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16" HeightRequest="68"/>
                        <Border Margin="20,6" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16" HeightRequest="68"/>
                        <Border Margin="20,6" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16" HeightRequest="68"/>
                        <Border Margin="20,6" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16" HeightRequest="68"/>
                        <Border Margin="20,6" StrokeThickness="0" BackgroundColor="#E8E1F6"
                                StrokeShape="RoundRectangle 16" HeightRequest="68"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Shimmer Sweep -->
                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#66FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
