<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Kaydol"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid>

        <!-- Steps 0-2: Scrollable content -->
        <Grid RowDefinitions="*,Auto"
              IsVisible="{Binding IsKvkkStep, Converter={StaticResource InvertedBoolConverter}}">
            <ScrollView>
                <VerticalStackLayout Spacing="0" Padding="28,18,28,0">

                    <!-- Title area -->
                    <Label Text="{Binding StepTitle}"
                           Style="{StaticResource AuthTitleStyle}"
                           Margin="0,0,0,6"/>

                    <Label Text="{Binding StepSubtitle}"
                           Style="{StaticResource AuthSubtitleStyle}"
                           Margin="0,0,0,22"/>

                    <!-- Error -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                           FontFamily="JakartaMedium" FontSize="13"
                           HorizontalTextAlignment="Start"
                           IsVisible="{Binding HasError}"
                           Margin="0,0,0,12"/>

                    <!-- STEP 0: Phone -->
                    <VerticalStackLayout Spacing="0" IsVisible="{Binding IsPhoneStep}">
                        <Label Text="TELEFON" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,20">
                            <Grid ColumnDefinitions="44,*" Padding="0">
                                <Image Source="icon_phone.png" WidthRequest="17" HeightRequest="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Entry Grid.Column="1" Placeholder="05XX XXX XX XX"
                                       Text="{Binding PhoneNumber}"
                                       Keyboard="Telephone" ReturnType="Done"
                                       MaxLength="11"
                                       Style="{StaticResource AuthFieldEntryStyle}"/>
                            </Grid>
                        </Border>

                        <Grid HeightRequest="52">
                            <Button Text="Kod Gönder"
                                    Command="{Binding SendOtpCommand}"
                                    IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                    Style="{StaticResource AuthPrimaryButtonStyle}"/>
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 26"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                    HeightRequest="52"
                                    IsVisible="{Binding IsBusy}">
                                <ActivityIndicator IsRunning="True"
                                                   Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                                   HeightRequest="24" WidthRequest="24"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- STEP 1: OTP -->
                    <VerticalStackLayout Spacing="0" IsVisible="{Binding IsOtpStep}">
                        <Label Text="DOĞRULAMA KODU" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,20">
                            <Grid ColumnDefinitions="44,*" Padding="0">
                                <Image Source="icon_lock.png" WidthRequest="17" HeightRequest="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Entry Grid.Column="1" Placeholder="6 haneli kod"
                                       Text="{Binding OtpCode}"
                                       Keyboard="Numeric" ReturnType="Done"
                                       MaxLength="6"
                                       Style="{StaticResource AuthFieldEntryStyle}"/>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Grid HeightRequest="52">
                                <Button Text="Doğrula"
                                        Command="{Binding VerifyOtpCommand}"
                                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                        Style="{StaticResource AuthPrimaryButtonStyle}"/>
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 26"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                        HeightRequest="52"
                                        IsVisible="{Binding IsBusy}">
                                    <ActivityIndicator IsRunning="True"
                                                       Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                                       HeightRequest="24" WidthRequest="24"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Button Grid.Column="1" Text="Geri"
                                    Command="{Binding GoBackCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                    Style="{StaticResource AuthOutlineButtonStyle}"/>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- STEP 2: Personal Info -->
                    <VerticalStackLayout Spacing="0" IsVisible="{Binding IsInfoStep}">

                        <!-- Name row -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout>
                                <Label Text="AD" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <Grid ColumnDefinitions="44,*" Padding="0">
                                        <Image Source="icon_user.png" WidthRequest="17" HeightRequest="17"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Entry Grid.Column="1" Placeholder="Ad" Text="{Binding FirstName}"
                                               MaxLength="50"
                                               Style="{StaticResource AuthFieldEntryStyle}"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="SOYAD" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <Grid ColumnDefinitions="44,*" Padding="0">
                                        <Image Source="icon_user.png" WidthRequest="17" HeightRequest="17"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Entry Grid.Column="1" Placeholder="Soyad" Text="{Binding LastName}"
                                               MaxLength="50"
                                               Style="{StaticResource AuthFieldEntryStyle}"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Email -->
                        <Label Text="E-POSTA" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                            <Grid ColumnDefinitions="44,*" Padding="0">
                                <Image Source="icon_mail.png" WidthRequest="17" HeightRequest="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Entry Grid.Column="1" Placeholder="ornek@email.com"
                                       Text="{Binding Email}" Keyboard="Email"
                                       MaxLength="100"
                                       Style="{StaticResource AuthFieldEntryStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Password -->
                        <Label Text="PAROLA" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,4">
                            <Grid ColumnDefinitions="44,*" Padding="0">
                                <Image Source="icon_lock.png" WidthRequest="17" HeightRequest="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Entry Grid.Column="1" Placeholder="En az 8 karakter"
                                       Text="{Binding Password}" IsPassword="True"
                                       MaxLength="64"
                                       Style="{StaticResource AuthFieldEntryStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Password Strength Bar -->
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4" Margin="0,0,0,4">
                            <BoxView BackgroundColor="{Binding StrengthColor1}" HeightRequest="4"
                                     CornerRadius="2"/>
                            <BoxView Grid.Column="1" BackgroundColor="{Binding StrengthColor2}" HeightRequest="4"
                                     CornerRadius="2"/>
                            <BoxView Grid.Column="2" BackgroundColor="{Binding StrengthColor3}" HeightRequest="4"
                                     CornerRadius="2"/>
                            <BoxView Grid.Column="3" BackgroundColor="{Binding StrengthColor4}" HeightRequest="4"
                                     CornerRadius="2"/>
                        </Grid>
                        <Label Text="{Binding StrengthLabel}"
                               FontFamily="JakartaSemiBold" FontSize="11"
                               TextColor="{Binding StrengthLabelColor}"
                               HorizontalTextAlignment="End"
                               Margin="0,0,0,10"/>

                        <!-- Password Confirm -->
                        <Label Text="PAROLA TEKRAR" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                            <Grid ColumnDefinitions="44,*" Padding="0">
                                <Image Source="icon_lock.png" WidthRequest="17" HeightRequest="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Entry Grid.Column="1" Placeholder="Parolayı tekrar girin"
                                       Text="{Binding PasswordConfirm}" IsPassword="True"
                                       MaxLength="64"
                                       Style="{StaticResource AuthFieldEntryStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}" Margin="0,4,0,14"/>

                        <!-- Pickers - all wrapped in same AuthFieldBorderStyle -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout>
                                <Label Text="CİNSİYET" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <Picker ItemsSource="{Binding GenderOptions}"
                                            SelectedIndex="{Binding SelectedGender}"
                                            FontFamily="JakartaMedium" FontSize="14"
                                            Margin="14,0"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="MEDENİ DURUM" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <Picker ItemsSource="{Binding MaritalStatusOptions}"
                                            SelectedIndex="{Binding SelectedMaritalStatus}"
                                            FontFamily="JakartaMedium" FontSize="14"
                                            Margin="14,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout>
                                <Label Text="DOĞUM TARİHİ" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <DatePicker Date="{Binding BirthDate}"
                                                MinimumDate="{Binding MinBirthDate}"
                                                MaximumDate="{Binding MaxBirthDate}"
                                                FontFamily="JakartaMedium" FontSize="14"
                                                Margin="14,0"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="GSM OPERATÖRÜ" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <Picker ItemsSource="{Binding GsmOperatorOptions}"
                                            SelectedIndex="{Binding SelectedGsmOperator}"
                                            FontFamily="JakartaMedium" FontSize="14"
                                            Margin="14,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout>
                                <Label Text="İL" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <Picker ItemsSource="{Binding Cities}"
                                            SelectedItem="{Binding SelectedCity}"
                                            ItemDisplayBinding="{Binding Name}"
                                            FontFamily="JakartaMedium" FontSize="14"
                                            Margin="14,0"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="İLÇE" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                    <Picker ItemsSource="{Binding Districts}"
                                            SelectedItem="{Binding SelectedDistrict}"
                                            ItemDisplayBinding="{Binding Name}"
                                            FontFamily="JakartaMedium" FontSize="14"
                                            Margin="14,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="MESLEK" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                            <Picker ItemsSource="{Binding Professions}"
                                    SelectedItem="{Binding SelectedProfession}"
                                    ItemDisplayBinding="{Binding Name}"
                                    FontFamily="JakartaMedium" FontSize="14"
                                    Margin="14,0"/>
                        </Border>

                        <Label Text="EĞİTİM DURUMU" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                            <Picker ItemsSource="{Binding EducationLevels}"
                                    SelectedItem="{Binding SelectedEducationLevel}"
                                    ItemDisplayBinding="{Binding Name}"
                                    FontFamily="JakartaMedium" FontSize="14"
                                    Margin="14,0"/>
                        </Border>

                        <HorizontalStackLayout Spacing="8" Margin="0,0,0,0">
                            <CheckBox IsChecked="{Binding IsRetired}" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                            <Label Text="Emekli" FontFamily="JakartaMedium" FontSize="14"
                                   VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                        </HorizontalStackLayout>

                        <!-- Hane Durumu -->
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}" Margin="0,14,0,14"/>
                        <Label Text="HANE DURUMU" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>

                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding IsHeadOfFamily}" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                            <Label Text="Hane Reisi misiniz?" FontFamily="JakartaMedium" FontSize="14"
                                   VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                        </HorizontalStackLayout>

                        <VerticalStackLayout Spacing="0"
                                             IsVisible="{Binding IsHeadOfFamily, Converter={StaticResource InvertedBoolConverter}}"
                                             Margin="0,8,0,0">
                            <HorizontalStackLayout Spacing="8" Margin="0,0,0,12">
                                <CheckBox IsChecked="{Binding IsHeadOfFamilyRetired}" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                <Label Text="Hane Reisi Emekli" FontFamily="JakartaMedium" FontSize="14"
                                       VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </HorizontalStackLayout>

                            <Label Text="HANE REİSİ MESLEK" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                <Picker ItemsSource="{Binding Professions}"
                                        SelectedItem="{Binding SelectedHofProfession}"
                                        ItemDisplayBinding="{Binding Name}"
                                        FontFamily="JakartaMedium" FontSize="14"
                                        Margin="14,0"/>
                            </Border>

                            <Label Text="HANE REİSİ EĞİTİM" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                                <Picker ItemsSource="{Binding EducationLevels}"
                                        SelectedItem="{Binding SelectedHofEducationLevel}"
                                        ItemDisplayBinding="{Binding Name}"
                                        FontFamily="JakartaMedium" FontSize="14"
                                        Margin="14,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Reference Code -->
                        <Label Text="REFERANS KODU (OPSİYONEL)" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,0"/>
                        <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,20">
                            <Grid ColumnDefinitions="44,*" Padding="0">
                                <Image Source="icon_star.png" WidthRequest="17" HeightRequest="17"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Entry Grid.Column="1" Placeholder="Referans kodunuz varsa girin"
                                       Text="{Binding ReferenceCode}"
                                       MaxLength="20"
                                       Style="{StaticResource AuthFieldEntryStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,40">
                            <Grid HeightRequest="52">
                                <Button Text="Devam"
                                        Command="{Binding GoToKvkkCommand}"
                                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                        Style="{StaticResource AuthPrimaryButtonStyle}"/>
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 26"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                        HeightRequest="52"
                                        IsVisible="{Binding IsBusy}">
                                    <ActivityIndicator IsRunning="True"
                                                       Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                                       HeightRequest="24" WidthRequest="24"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Button Grid.Column="1" Text="Geri"
                                    Command="{Binding GoBackCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                    Style="{StaticResource AuthOutlineButtonStyle}"/>
                        </Grid>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom Link (steps 0-2) -->
            <HorizontalStackLayout Grid.Row="1" Spacing="4"
                                    HorizontalOptions="Center"
                                    Padding="0,16,0,32">
                <Label Text="Zaten hesabın var mı?"
                       Style="{StaticResource AuthBottomLinkStyle}"/>
                <Label Text="Giriş Yap"
                       Style="{StaticResource AuthLinkStyle}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </Grid>

        <!-- STEP 3: KVKK - Full screen layout -->
        <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="28,24"
              IsVisible="{Binding IsKvkkStep}">

            <Label Text="KVKK Onayı"
                   Style="{StaticResource AuthTitleStyle}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,12"/>

            <Border Grid.Row="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}" Padding="16">
                <ScrollView>
                    <Label FontFamily="JakartaMedium" FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           LineBreakMode="WordWrap"
                           Text="{Binding KvkkText}"/>
                </ScrollView>
            </Border>

            <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,12,0,0">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                       FontFamily="JakartaMedium" FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding HasError}"/>

                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <CheckBox IsChecked="{Binding KvkkAccepted}" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                    <Label Text="KVKK metnini okudum ve onaylıyorum."
                           FontFamily="JakartaSemiBold" FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,16">
                <Grid HeightRequest="52">
                    <Button Text="Kaydol"
                            Command="{Binding RegisterCommand}"
                            IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            Style="{StaticResource AuthPrimaryButtonStyle}"/>
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 26"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                            HeightRequest="52"
                            IsVisible="{Binding IsBusy}">
                        <ActivityIndicator IsRunning="True"
                                           Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                           HeightRequest="24" WidthRequest="24"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>
                <Button Grid.Column="1" Text="Geri"
                        Command="{Binding GoBackCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{StaticResource AuthOutlineButtonStyle}"/>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
