<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             x:Class="PulsePoll.Mobile.Views.SurveysPage"
             x:DataType="vm:SurveysViewModel"
             Shell.NavBarIsVisible="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="12" Padding="20,16">
                <Label Text="Anketler" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,4"/>

                <VerticalStackLayout Spacing="12"
                                     BindableLayout.ItemsSource="{Binding Surveys}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:SurveyModel">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SurveysViewModel}}, Path=OpenSurveyCommand}"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Text="{Binding Title}"
                                               FontFamily="JakartaSemiBold" FontSize="16"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center"/>
                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                BackgroundColor="{StaticResource AmberLight}"
                                                Padding="10,4"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding RewardDisplay}"
                                                   FontFamily="JakartaSemiBold" FontSize="13"
                                                   TextColor="#111111"/>
                                        </Border>
                                    </Grid>

                                    <Label Text="{Binding Description}"
                                           Style="{StaticResource BodyStyle}"
                                           MaxLines="3"
                                           LineBreakMode="TailTruncation"
                                           IsVisible="{Binding HasDescription}"/>

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{StaticResource SurfaceColor}"
                                                Padding="10,4">
                                            <HorizontalStackLayout Spacing="4">
                                                <Image Source="icon_clock.png" HeightRequest="14" WidthRequest="14" VerticalOptions="Center"/>
                                                <Label Text="{Binding DurationMinutes, StringFormat='~{0} dk'}"
                                                       Style="{StaticResource CaptionStyle}" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>

                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{StaticResource PrimaryLight}"
                                                Padding="10,4"
                                                IsVisible="{Binding HasCategory}"
                                                HorizontalOptions="End">
                                            <Label Text="{Binding Category}" FontFamily="JakartaMedium" FontSize="11"
                                                   TextColor="{StaticResource PrimaryPurple}"/>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <BoxView HeightRequest="20" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsVisible="{Binding IsLoading}"
                           IsRunning="{Binding IsLoading}"
                           Color="{StaticResource PrimaryPurple}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
    </Grid>
</ContentPage>
