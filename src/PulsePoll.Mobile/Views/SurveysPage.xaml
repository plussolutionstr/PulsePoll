<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:PulsePoll.Mobile.Controls"
             x:Class="PulsePoll.Mobile.Views.SurveysPage"
             x:DataType="vm:SurveysViewModel"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- ══════ MAIN CONTENT ══════ -->
        <ScrollView x:Name="MainContent">
            <ScrollView.Triggers>
                <DataTrigger TargetType="ScrollView"
                             Binding="{Binding IsLoading}"
                             Value="True">
                    <Setter Property="IsVisible" Value="False"/>
                </DataTrigger>
            </ScrollView.Triggers>
            <VerticalStackLayout Spacing="12" Padding="20,16">
                <Label Text="Anketler" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,4"/>

                <VerticalStackLayout Spacing="12"
                                     BindableLayout.ItemsSource="{Binding Surveys}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:SurveyModel">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SurveysViewModel}}, Path=OpenSurveyCommand}"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Text="{Binding Title}"
                                               FontFamily="JakartaSemiBold" FontSize="16"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                               VerticalOptions="Center"/>
                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource AmberLight}, Dark={StaticResource AmberLightDark}}"
                                                Padding="10,4"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding RewardDisplay}"
                                                   FontFamily="JakartaSemiBold" FontSize="13"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                        </Border>
                                    </Grid>

                                    <Label Text="{Binding Description}"
                                           Style="{StaticResource BodyStyle}"
                                           MaxLines="3"
                                           LineBreakMode="TailTruncation"
                                           IsVisible="{Binding HasDescription}"/>

                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColor}, Dark={StaticResource SurfaceColorDark}}"
                                                Padding="10,4">
                                            <HorizontalStackLayout Spacing="4">
                                                <Image Source="icon_clock.png" HeightRequest="14" WidthRequest="14" VerticalOptions="Center">
                                                    <Image.Behaviors>
                                                        <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                                    </Image.Behaviors>
                                                </Image>
                                                <Label Text="{Binding DurationMinutes, StringFormat='~{0} dk'}"
                                                       Style="{StaticResource CaptionStyle}" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>

                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                                Padding="10,4"
                                                IsVisible="{Binding HasCategory}"
                                                HorizontalOptions="End">
                                            <Label Text="{Binding Category}" FontFamily="JakartaMedium" FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <BoxView HeightRequest="20" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Empty State -->
        <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="16"
                             Padding="40,0">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 40"
                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                    HeightRequest="80" WidthRequest="80"
                    HorizontalOptions="Center">
                <Label Text="&#x1F4CB;"
                       FontSize="36"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
            <Label Text="Henüz aktif anket yok"
                   FontFamily="JakartaSemiBold"
                   FontSize="18"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Yeni anketler eklendiğinde burada görünecek. Takipte kal!"
                   FontFamily="JakartaRegular"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"/>
        </VerticalStackLayout>

        <!-- ══════ SHIMMER OVERLAY ══════ -->
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <ScrollView>
                    <VerticalStackLayout Spacing="12" Padding="20,16">
                        <!-- Title -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="26" WidthRequest="110"
                                HorizontalOptions="Start" Margin="0,0,0,4"/>

                        <!-- Survey Card Skeletons -->
                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="16">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                                StrokeShape="RoundRectangle 6"
                                                HeightRequest="18" WidthRequest="180"
                                                HorizontalOptions="Start"/>
                                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerAmber}, Dark={StaticResource ShimmerAmberDark}}"
                                                StrokeShape="RoundRectangle 10"
                                                HeightRequest="24" WidthRequest="60"/>
                                    </Grid>
                                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="14" HorizontalOptions="Fill"/>
                                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="14" WidthRequest="220"
                                            HorizontalOptions="Start"/>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                                StrokeShape="RoundRectangle 8"
                                                HeightRequest="26" WidthRequest="80"/>
                                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                                StrokeShape="RoundRectangle 8"
                                                HeightRequest="26" WidthRequest="70"
                                                HorizontalOptions="End"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="16">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                                StrokeShape="RoundRectangle 6"
                                                HeightRequest="18" WidthRequest="200"
                                                HorizontalOptions="Start"/>
                                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerAmber}, Dark={StaticResource ShimmerAmberDark}}"
                                                StrokeShape="RoundRectangle 10"
                                                HeightRequest="24" WidthRequest="55"/>
                                    </Grid>
                                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="14" HorizontalOptions="Fill"/>
                                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="14" WidthRequest="190"
                                            HorizontalOptions="Start"/>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                                StrokeShape="RoundRectangle 8"
                                                HeightRequest="26" WidthRequest="80"/>
                                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                                StrokeShape="RoundRectangle 8"
                                                HeightRequest="26" WidthRequest="65"
                                                HorizontalOptions="End"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="16">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                                StrokeShape="RoundRectangle 6"
                                                HeightRequest="18" WidthRequest="160"
                                                HorizontalOptions="Start"/>
                                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerAmber}, Dark={StaticResource ShimmerAmberDark}}"
                                                StrokeShape="RoundRectangle 10"
                                                HeightRequest="24" WidthRequest="50"/>
                                    </Grid>
                                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="14" HorizontalOptions="Fill"/>
                                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 4"
                                            HeightRequest="14" WidthRequest="170"
                                            HorizontalOptions="Start"/>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                                StrokeShape="RoundRectangle 8"
                                                HeightRequest="26" WidthRequest="80"/>
                                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                                StrokeShape="RoundRectangle 8"
                                                HeightRequest="26" WidthRequest="75"
                                                HorizontalOptions="End"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Shimmer Sweep -->
                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource ShimmerSweepHighlight}, Dark={StaticResource ShimmerSweepHighlightDark}}" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
        <controls:ConnectionErrorOverlay IsVisible="{Binding HasConnectionError}"
                                         RetryCommand="{Binding RetryConnectionCommand}"/>
    </Grid>
</ContentPage>
