<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             x:Class="PulsePoll.Mobile.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- Top Bar -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <Label Text="PulsePoll"
                       Style="{StaticResource PageTitleStyle}"
                       FontSize="24"
                       TextColor="{StaticResource PrimaryPurple}"
                       VerticalOptions="Center"/>
                <ImageButton Grid.Column="1"
                             Source="icon_bell.png"
                             HeightRequest="24" WidthRequest="24"
                             Command="{Binding NavigateToNotificationsCommand}"
                             VerticalOptions="Center"/>
            </Grid>

            <!-- Stories -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="16"
                                       BindableLayout.ItemsSource="{Binding Stories}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:StoryModel">
                            <VerticalStackLayout Spacing="6" WidthRequest="68">
                                <Border StrokeThickness="3"
                                        Stroke="{StaticResource PrimaryPurple}"
                                        StrokeShape="RoundRectangle 32"
                                        HeightRequest="64" WidthRequest="64"
                                        HorizontalOptions="Center"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        Padding="2">
                                    <Label Text="{Binding BrandName, StringFormat='{0:0}'}"
                                           FontFamily="JakartaBold" FontSize="11"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           TextColor="{StaticResource PrimaryPurple}"
                                           HorizontalTextAlignment="Center"
                                           MaxLines="2" LineBreakMode="TailTruncation"/>
                                </Border>
                                <Label Text="{Binding BrandName}"
                                       Style="{StaticResource CaptionStyle}"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Featured News Banner -->
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding News}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:NewsModel">
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                Padding="20"
                                HeightRequest="140">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource PrimaryPurple}" Offset="0"/>
                                    <GradientStop Color="{StaticResource PrimaryDark}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="#50FFFFFF"
                                        Padding="8,4"
                                        HorizontalOptions="Start">
                                    <Label Text="{Binding Tag}"
                                           FontFamily="JakartaSemiBold" FontSize="11"
                                           TextColor="White"/>
                                </Border>
                                <Label Text="{Binding Title}"
                                       FontFamily="JakartaBold" FontSize="18"
                                       TextColor="White"/>
                                <Label Text="{Binding Subtitle}"
                                       FontFamily="JakartaRegular" FontSize="13"
                                       TextColor="#CCFFFFFF"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Sana Özel Header -->
            <Label Text="Sana Özel Anketler"
                   Style="{StaticResource TitleStyle}"
                   Margin="0,4,0,0"/>

            <!-- ====== VISUAL SURVEY CARDS (01B) ====== -->
            <VerticalStackLayout Spacing="12"
                                 BindableLayout.ItemsSource="{Binding Surveys}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:SurveyModel">
                        <Border StrokeShape="RoundRectangle 20"
                                Stroke="{StaticResource CardBorder}"
                                StrokeThickness="1"
                                BackgroundColor="{StaticResource White}"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToSurveyDetailCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout>

                                <!-- Banner Area with Gradient -->
                                <Grid HeightRequest="110">
                                    <!-- Gradient Background -->
                                    <BoxView>
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{StaticResource PrimaryLight}" Offset="0"/>
                                                <GradientStop Color="{StaticResource PrimaryMid}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>

                                    <!-- Decorative Circle -->
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 50"
                                            HeightRequest="100" WidthRequest="100"
                                            BackgroundColor="#10000000"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start"
                                            Margin="0,-10,-10,0"/>

                                    <!-- Image Placeholder Icon -->
                                    <Image Source="icon_star.png"
                                           HeightRequest="40" WidthRequest="40"
                                           Opacity="0.15"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                    <!-- Brand Badge (top-left) -->
                                    <HorizontalStackLayout Spacing="8"
                                                           Margin="12,12,0,0"
                                                           VerticalOptions="Start"
                                                           HorizontalOptions="Start">
                                        <Border StrokeThickness="1"
                                                Stroke="{StaticResource CardBorder}"
                                                StrokeShape="RoundRectangle 10"
                                                HeightRequest="32" WidthRequest="32"
                                                BackgroundColor="{StaticResource White}">
                                            <Label Text="{Binding BrandName, StringFormat='{0:0}'}"
                                                   FontFamily="JakartaExtraBold" FontSize="12"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   TextColor="{StaticResource PrimaryPurple}"
                                                   MaxLines="1"/>
                                        </Border>
                                        <Label Text="{Binding BrandName}"
                                               FontFamily="JakartaBold" FontSize="12"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <!-- Earn Badge (top-right) -->
                                    <Border StrokeThickness="1"
                                            Stroke="#FDE68A"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{StaticResource AmberLight}"
                                            Padding="10,4"
                                            Margin="0,12,12,0"
                                            VerticalOptions="Start"
                                            HorizontalOptions="End">
                                        <Label Text="{Binding Reward, StringFormat='₺{0}'}"
                                               FontFamily="JakartaBold" FontSize="13"
                                               TextColor="{StaticResource Amber}"/>
                                    </Border>
                                </Grid>

                                <!-- Card Body -->
                                <VerticalStackLayout Spacing="10" Padding="16,12,16,14">
                                    <!-- Title -->
                                    <Label Text="{Binding Title}"
                                           FontFamily="JakartaBold" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"/>

                                    <!-- Meta + Category -->
                                    <Grid ColumnDefinitions="Auto,Auto,*">
                                        <!-- Duration Chip -->
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{StaticResource SurfaceColor}"
                                                Padding="10,4"
                                                Margin="0,0,8,0">
                                            <HorizontalStackLayout Spacing="4">
                                                <Image Source="icon_clock.png"
                                                       HeightRequest="12" WidthRequest="12"
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding DurationMinutes, StringFormat='~{0} dk'}"
                                                       FontFamily="JakartaMedium" FontSize="12"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>

                                        <!-- Question Count Chip -->
                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{StaticResource SurfaceColor}"
                                                Padding="10,4">
                                            <HorizontalStackLayout Spacing="4">
                                                <Image Source="icon_check.png"
                                                       HeightRequest="12" WidthRequest="12"
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding QuestionCount, StringFormat='{0} soru'}"
                                                       FontFamily="JakartaMedium" FontSize="12"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>

                                        <!-- Category Tag (pushed right) -->
                                        <Border Grid.Column="2"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{StaticResource PrimaryLight}"
                                                Padding="10,4"
                                                HorizontalOptions="End">
                                            <Label Text="{Binding Category}"
                                                   FontFamily="JakartaSemiBold" FontSize="11"
                                                   TextColor="{StaticResource PrimaryPurple}"/>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Bottom spacing for TabBar -->
            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
