<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             xmlns:controls="clr-namespace:PulsePoll.Mobile.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PulsePoll.Mobile.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False">
    <Grid>
    <RefreshView x:Name="MainContent"
                 Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsRefreshing}">
        <RefreshView.Triggers>
            <DataTrigger TargetType="RefreshView"
                         Binding="{Binding IsLoading}"
                         Value="True">
                <Setter Property="IsVisible" Value="False"/>
            </DataTrigger>
        </RefreshView.Triggers>
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- ══════ TOP BAR ══════ -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <Label Text="PulsePoll"
                       Style="{StaticResource PageTitleStyle}"
                       FontSize="24"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                       VerticalOptions="Center"/>
                <!-- Bell with red notification dot -->
                <Grid Grid.Column="1" VerticalOptions="Center">
                    <ImageButton Source="icon_bell.png"
                                 HeightRequest="24" WidthRequest="24"
                                 Command="{Binding NavigateToNotificationsCommand}">
                        <ImageButton.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 5"
                            HeightRequest="10" WidthRequest="10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                            IsVisible="{Binding HasUnreadNotifications}"
                            HorizontalOptions="End" VerticalOptions="Start"
                            Margin="0,-2,-2,0"/>
                </Grid>
            </Grid>

            <!-- ══════ STORIES ══════ -->
            <ScrollView x:Name="CoachStories" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="14"
                                       BindableLayout.ItemsSource="{Binding Stories}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:StoryModel">
                            <VerticalStackLayout Spacing="6" WidthRequest="68">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=OpenStoryCommand}"
                                        CommandParameter="{Binding .}"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <!-- Story ring — gradient ring simulated with border -->
                                <Border StrokeThickness="2.5"
                                        Stroke="{Binding RingStroke}"
                                        StrokeShape="RoundRectangle 30"
                                        HeightRequest="60" WidthRequest="60"
                                        HorizontalOptions="Center"
                                        Padding="3">
                                    <!-- Inner circle — image placeholder -->
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 25"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColor}, Dark={StaticResource SurfaceColorDark}}">
                                        <Grid>
                                            <Image Source="icon_star.png"
                                                   HeightRequest="24" WidthRequest="24"
                                                   Opacity="0.3"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                            <Image Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill"/>
                                        </Grid>
                                    </Border>
                                </Border>
                                <Label Text="{Binding Title}"
                                       FontFamily="JakartaMedium" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- ══════ NEWS SLIDER ══════ -->
            <Border x:Name="CoachNewsSlider"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    HeightRequest="160"
                    Padding="0">
                <Grid>
                    <CarouselView x:Name="newsCarousel"
                                  ItemsSource="{Binding News}"
                                  Loop="False"
                                  PeekAreaInsets="0"
                                  IndicatorView="{x:Reference newsIndicator}">
                        <CarouselView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               SnapPointsType="MandatorySingle"
                                               SnapPointsAlignment="Center"
                                               ItemSpacing="0"/>
                        </CarouselView.ItemsLayout>
                        <CarouselView.ItemTemplate>
                            <DataTemplate x:DataType="models:NewsModel">
                                <Grid>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=OpenNewsCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>
                                    <BoxView BackgroundColor="#1A1535"/>
                                    <Image Source="icon_star.png"
                                           HeightRequest="48" WidthRequest="48"
                                           Opacity="0.1"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"/>

                                    <!-- Decorative circles -->
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 70"
                                            HeightRequest="140" WidthRequest="140"
                                            BackgroundColor="#12FFFFFF"
                                            HorizontalOptions="End" VerticalOptions="Start"
                                            Margin="0,-20,-20,0"/>
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 50"
                                            HeightRequest="100" WidthRequest="100"
                                            BackgroundColor="#0DFFFFFF"
                                            HorizontalOptions="Start" VerticalOptions="End"
                                            Margin="20,0,0,-30"/>

                                    <!-- Soft bottom fade for title readability -->
                                    <BoxView VerticalOptions="End"
                                             HeightRequest="78">
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00151235" Offset="0"/>
                                                <GradientStop Color="#CC151235" Offset="1"/>
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>

                                    <!-- Text content -->
                                    <VerticalStackLayout Spacing="4"
                                                         VerticalOptions="End"
                                                         Padding="16,0,16,8">
                                        <Label Text="{Binding Title}"
                                               FontFamily="JakartaExtraBold" FontSize="15"
                                               TextColor="White"
                                               LineHeight="1.35"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>

                    <!-- Indicator dots (bottom-right, inside banner) -->
                    <IndicatorView x:Name="newsIndicator"
                                   HorizontalOptions="End"
                                   VerticalOptions="End"
                                   Margin="0,0,16,12"
                                   IndicatorColor="#66FFFFFF"
                                   SelectedIndicatorColor="#E6FFFFFF"
                                   IndicatorSize="6"/>
                </Grid>
            </Border>

            <!-- ══════ SECTION HEADER ══════ -->
            <Grid x:Name="CoachSurveyHeader" ColumnDefinitions="*,Auto">
                <Label Text="Sana Özel"
                       Style="{StaticResource TitleStyle}"/>
                <Label Grid.Column="1"
                       Text="Tümü"
                       FontFamily="JakartaSemiBold" FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToSurveysCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- ══════ NO SURVEYS EMPTY STATE ══════ -->
            <Border IsVisible="{Binding HasNoSurveys}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                    Padding="20,28">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 32"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                            HeightRequest="64" WidthRequest="64"
                            HorizontalOptions="Center">
                        <Label Text="&#x1F4CB;"
                               FontSize="28"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Şu an aktif anket yok"
                           FontFamily="JakartaSemiBold"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Yeni anketler yayınlandığında burada görünecek."
                           FontFamily="JakartaRegular"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- ══════ SURVEY CARDS (VISUAL) ══════ -->
            <VerticalStackLayout Spacing="12"
                                 BindableLayout.ItemsSource="{Binding Surveys}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:SurveyModel">
                        <Border StrokeShape="RoundRectangle 20"
                                Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToSurveyDetailCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout>

                                <!-- Banner — survey visual area -->
                                <Grid HeightRequest="120">
                                    <!-- Gradient background (brand-specific colors via code-behind later) -->
                                    <BoxView>
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}" Offset="0"/>
                                                <GradientStop Color="{AppThemeBinding Light={StaticResource PrimaryMid}, Dark={StaticResource PrimaryMidDark}}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>

                                    <!-- Decorative circles -->
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 50"
                                            HeightRequest="100" WidthRequest="100"
                                            BackgroundColor="#08000000"
                                            HorizontalOptions="End" VerticalOptions="Start"
                                            Margin="0,-10,-10,0"/>
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 40"
                                            HeightRequest="80" WidthRequest="80"
                                            BackgroundColor="#05000000"
                                            HorizontalOptions="Start" VerticalOptions="End"
                                            Margin="30,0,0,-20"/>

                                    <Grid>
                                        <Image Source="icon_star.png"
                                               HeightRequest="40" WidthRequest="40"
                                               Opacity="0.15"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                        <Image Source="{Binding BrandLogoUrl}"
                                               Aspect="AspectFill"/>
                                    </Grid>

                                    <!-- Earn Badge (top-right) -->
                                    <Border StrokeThickness="1"
                                            Stroke="{AppThemeBinding Light={StaticResource AmberBorder}, Dark={StaticResource AmberBorderDark}}"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource AmberLight}, Dark={StaticResource AmberLightDark}}"
                                            Padding="10,4"
                                            Margin="0,12,12,0"
                                            VerticalOptions="Start"
                                            HorizontalOptions="End">
                                        <Label Text="{Binding RewardDisplay}"
                                               FontFamily="JakartaBold" FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    </Border>
                                </Grid>

                                <!-- Card Body -->
                                <VerticalStackLayout Spacing="10" Padding="16,12,16,14">
                                    <Label Text="{Binding Title}"
                                           FontFamily="JakartaExtraBold" FontSize="15"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>

                                    <!-- Duration + Category -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColor}, Dark={StaticResource SurfaceColorDark}}"
                                                Padding="10,4">
                                            <HorizontalStackLayout Spacing="4">
                                                <Image Source="icon_clock.png"
                                                       HeightRequest="12" WidthRequest="12"
                                                       VerticalOptions="Center">
                                                    <Image.Behaviors>
                                                        <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                                    </Image.Behaviors>
                                                </Image>
                                                <Label Text="{Binding DurationMinutes, StringFormat='~{0} dk'}"
                                                       FontFamily="JakartaMedium" FontSize="12"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>

                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                                Padding="10,4"
                                                IsVisible="{Binding HasCategory}"
                                                HorizontalOptions="End">
                                            <Label Text="{Binding Category}"
                                                   FontFamily="JakartaSemiBold" FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Bottom spacing for TabBar -->
            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>
    </RefreshView>
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <ScrollView>
                    <VerticalStackLayout Spacing="16" Padding="20,16">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                    StrokeShape="RoundRectangle 8"
                                    HeightRequest="26"
                                    WidthRequest="130"
                                    HorizontalOptions="Start"/>
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                    StrokeShape="RoundRectangle 12"
                                    HeightRequest="24"
                                    WidthRequest="24"
                                    HorizontalOptions="End"/>
                        </Grid>

                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Spacing="14">
                                <VerticalStackLayout Spacing="6" WidthRequest="68">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 30"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            HorizontalOptions="Center"/>
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                            StrokeShape="RoundRectangle 6"
                                            HeightRequest="11"
                                            WidthRequest="52"
                                            HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6" WidthRequest="68">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 30"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            HorizontalOptions="Center"/>
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                            StrokeShape="RoundRectangle 6"
                                            HeightRequest="11"
                                            WidthRequest="52"
                                            HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6" WidthRequest="68">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 30"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            HorizontalOptions="Center"/>
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                            StrokeShape="RoundRectangle 6"
                                            HeightRequest="11"
                                            WidthRequest="52"
                                            HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6" WidthRequest="68">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 30"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            HorizontalOptions="Center"/>
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                            StrokeShape="RoundRectangle 6"
                                            HeightRequest="11"
                                            WidthRequest="52"
                                            HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6" WidthRequest="68">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                            StrokeShape="RoundRectangle 30"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            HorizontalOptions="Center"/>
                                    <Border StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                            StrokeShape="RoundRectangle 6"
                                            HeightRequest="11"
                                            WidthRequest="52"
                                            HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </ScrollView>

                        <Border StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                StrokeShape="RoundRectangle 16"
                                HeightRequest="160"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                    StrokeShape="RoundRectangle 8"
                                    HeightRequest="24"
                                    WidthRequest="120"
                                    HorizontalOptions="Start"/>
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                    StrokeShape="RoundRectangle 6"
                                    HeightRequest="18"
                                    WidthRequest="48"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <VerticalStackLayout Spacing="12">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 20"
                                    HeightRequest="222"/>
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 20"
                                    HeightRequest="222"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource ShimmerSweepHighlight}, Dark={StaticResource ShimmerSweepHighlightDark}}" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
        <controls:CoachMarkOverlay x:Name="CoachMark" Key="home"/>
        <controls:ConnectionErrorOverlay IsVisible="{Binding HasConnectionError}"
                                         RetryCommand="{Binding RetryConnectionCommand}"/>
    </Grid>
</ContentPage>
