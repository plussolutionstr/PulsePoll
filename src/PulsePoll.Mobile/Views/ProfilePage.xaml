<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:models="clr-namespace:PulsePoll.Mobile.Models"
             x:Class="PulsePoll.Mobile.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <Label Text="Profil" Style="{StaticResource PageTitleStyle}"/>

            <!-- Avatar Card -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border StrokeThickness="3"
                            Stroke="{StaticResource PrimaryPurple}"
                            StrokeShape="RoundRectangle 40"
                            HeightRequest="80" WidthRequest="80"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            HorizontalOptions="Center">
                        <Label Text="{Binding FullName, StringFormat='{0:0}'}"
                               FontFamily="JakartaBold" FontSize="24"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{StaticResource PrimaryPurple}"/>
                    </Border>
                    <Label Text="{Binding FullName}"
                           FontFamily="JakartaBold" FontSize="18"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding Email}"
                           Style="{StaticResource BodyStyle}"
                           HorizontalTextAlignment="Center"/>
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{StaticResource AmberLight}"
                            Padding="12,6"
                            HorizontalOptions="Center">
                        <Label FontFamily="JakartaSemiBold" FontSize="13" TextColor="{StaticResource Amber}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="🥇 "/>
                                    <Span Text="{Binding Tier}"/>
                                    <Span Text=" · "/>
                                    <Span Text="{Binding Points, StringFormat='{0:N0}'}"/>
                                    <Span Text=" Puan"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Stats Row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Border StrokeShape="RoundRectangle 16" Stroke="{StaticResource CardBorder}"
                        BackgroundColor="{StaticResource White}" Padding="12,16">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding CompletedCount}"
                               FontFamily="JakartaBold" FontSize="20"
                               TextColor="{StaticResource PrimaryPurple}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Tamamlanan" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="{StaticResource CardBorder}"
                        BackgroundColor="{StaticResource White}" Padding="12,16">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding DisqualifiedCount}"
                               FontFamily="JakartaBold" FontSize="20"
                               TextColor="{StaticResource Danger}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Elenen" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" StrokeShape="RoundRectangle 16" Stroke="{StaticResource CardBorder}"
                        BackgroundColor="{StaticResource White}" Padding="12,16">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding SuccessRate, StringFormat='%{0}'}"
                               FontFamily="JakartaBold" FontSize="20"
                               TextColor="{StaticResource Success}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Başarı" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Demographics -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Demografik Bilgiler"
                           FontFamily="JakartaSemiBold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Grid ColumnDefinitions="*,*" RowSpacing="12" ColumnSpacing="12"
                          BindableLayout.ItemsSource="{Binding Demographics}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:DemographicField">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Label}"
                                           Style="{StaticResource CaptionStyle}"/>
                                    <Label Text="{Binding Value}"
                                           FontFamily="JakartaSemiBold" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Interests -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="İlgi Alanları"
                           FontFamily="JakartaSemiBold" FontSize="16"
                           TextColor="{StaticResource TextPrimary}"/>
                    <FlexLayout Wrap="Wrap" JustifyContent="Start"
                                BindableLayout.ItemsSource="{Binding Interests}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        Padding="12,6"
                                        Margin="0,0,8,8">
                                    <Label Text="{Binding .}"
                                           FontFamily="JakartaMedium" FontSize="13"
                                           TextColor="{StaticResource PrimaryPurple}"/>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="20" Color="Transparent"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
