<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             xmlns:controls="clr-namespace:PulsePoll.Mobile.Controls"
             x:Class="PulsePoll.Mobile.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        <converters:StarConverter x:Key="StarConverter"/>
        <converters:EditButtonTextConverter x:Key="EditButtonTextConverter"/>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
        <converters:GenderDisplayConverter x:Key="GenderDisplayConverter"/>
        <converters:MaritalStatusDisplayConverter x:Key="MaritalStatusDisplayConverter"/>
        <converters:GsmOperatorDisplayConverter x:Key="GsmOperatorDisplayConverter"/>
    </ContentPage.Resources>

    <Grid>
        <!-- ══════ MAIN CONTENT ══════ -->
        <ScrollView x:Name="MainContent">
            <ScrollView.Triggers>
                <DataTrigger TargetType="ScrollView"
                             Binding="{Binding IsLoading}"
                             Value="True">
                    <Setter Property="IsVisible" Value="False"/>
                </DataTrigger>
            </ScrollView.Triggers>
            <VerticalStackLayout Spacing="16" Padding="20,16">

                <Label Text="Profil" Style="{StaticResource PageTitleStyle}"/>

                <!-- Status Message -->
                <Label Text="{Binding StatusMessage}"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringToBoolConverter}}"
                       FontFamily="JakartaMedium" FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                       HorizontalTextAlignment="Center"/>

                <!-- Avatar Card -->
                <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <!-- Avatar with camera overlay -->
                    <Grid HeightRequest="88" WidthRequest="88" HorizontalOptions="Center">
                        <!-- Avatar circle (initials) -->
                        <Border StrokeThickness="3"
                                Stroke="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                StrokeShape="RoundRectangle 44"
                                HeightRequest="88" WidthRequest="88"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                HorizontalOptions="Center"
                                IsVisible="{Binding HasProfilePhoto, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="{Binding Initials}"
                                   FontFamily="JakartaBold" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                        </Border>
                        <!-- Profile photo -->
                        <Border StrokeThickness="3"
                                Stroke="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                StrokeShape="RoundRectangle 44"
                                HeightRequest="88" WidthRequest="88"
                                IsVisible="{Binding HasProfilePhoto}"
                                HorizontalOptions="Center">
                            <Image Source="{Binding ProfilePhotoSource}"
                                   Aspect="AspectFill"/>
                        </Border>
                        <!-- Camera icon -->
                        <Border StrokeThickness="2"
                                Stroke="{StaticResource White}"
                                StrokeShape="RoundRectangle 14"
                                HeightRequest="30" WidthRequest="30"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                HorizontalOptions="End" VerticalOptions="End"
                                Margin="0,0,2,2">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickPhotoCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="✎" FontSize="15"
                                   TextColor="{StaticResource White}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Full Name -->
                    <Label Text="{Binding FullName}"
                           FontFamily="JakartaBold" FontSize="18"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           HorizontalTextAlignment="Center"/>

                    <!-- Referral Code (tappable to copy) -->
                    <Border x:Name="CoachReferral"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                            Padding="14,8"
                            HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CopyReferralCodeCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding ReferralCode}"
                                   FontFamily="JakartaSemiBold" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                   VerticalOptions="Center"/>
                            <Label Text="⧉" FontSize="16" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Stars -->
                    <Label x:Name="CoachStars" FontFamily="JakartaBold" FontSize="22"
                           TextColor="{AppThemeBinding Light={StaticResource Amber}, Dark={StaticResource AmberDark}}"
                           HorizontalTextAlignment="Center"
                           Text="{Binding Star, Converter={StaticResource StarConverter}}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Stats Row -->
            <Grid x:Name="CoachStats" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Border StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}" Padding="12,16">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding CompletedCount}"
                               FontFamily="JakartaBold" FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Tamamlanan" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}" Padding="12,16">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding DisqualifiedCount}"
                               FontFamily="JakartaBold" FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Elenen" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" StrokeShape="RoundRectangle 16" Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}" Padding="12,16">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                        <Label Text="{Binding SuccessRate, StringFormat='%{0}'}"
                               FontFamily="JakartaBold" FontSize="20"
                               TextColor="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource SuccessDark}}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Başarı" FontFamily="JakartaMedium" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Profile Info Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Profil Bilgileri"
                               FontFamily="JakartaSemiBold" FontSize="16"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                        <Button Grid.Column="1"
                                Text="{Binding IsEditing, Converter={StaticResource EditButtonTextConverter}}"
                                FontFamily="JakartaSemiBold" FontSize="12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                Padding="12,6"
                                CornerRadius="12"
                                BorderWidth="0"
                                Command="{Binding ToggleEditCommand}"/>
                    </Grid>

                    <!-- Read-Only View -->
                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}">
                        <!-- Ad / Soyad -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Ad" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding FirstName}" FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Soyad" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding LastName}" FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>
                        <!-- E-posta / Telefon -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="E-posta" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding Email}" FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Telefon" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding PhoneNumber}" FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>
                        <!-- Cinsiyet / Doğum Tarihi -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Cinsiyet" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding SelectedGender, Converter={StaticResource GenderDisplayConverter}}"
                                       FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Doğum Tarihi" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding BirthDateDisplay}" FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>
                        <!-- Medeni Durum / GSM -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Medeni Durum" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding SelectedMaritalStatus, Converter={StaticResource MaritalStatusDisplayConverter}}"
                                       FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="GSM Operatörü" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding SelectedGsmOperator, Converter={StaticResource GsmOperatorDisplayConverter}}"
                                       FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>
                        <!-- İl / İlçe -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="İl" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding SelectedCity.Name}" FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="İlçe" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding SelectedDistrict.Name}" FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>
                        <!-- Meslek (tek satır) -->
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Meslek" Style="{StaticResource CaptionStyle}"/>
                            <Label Text="{Binding SelectedProfession.Name}" FontFamily="JakartaSemiBold" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                        </VerticalStackLayout>
                        <!-- Eğitim Durumu (tek satır) -->
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Eğitim Durumu" Style="{StaticResource CaptionStyle}"/>
                            <Label Text="{Binding SelectedEducationLevel.Name}" FontFamily="JakartaSemiBold" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                        </VerticalStackLayout>
                        <!-- Emekli / Hane Reisi -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Emekli" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding IsRetired, Converter={StaticResource BoolToYesNoConverter}}"
                                       FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Hane Reisi" Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding IsHeadOfFamily, Converter={StaticResource BoolToYesNoConverter}}"
                                       FontFamily="JakartaSemiBold" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Edit View -->
                    <VerticalStackLayout Spacing="14" IsVisible="{Binding IsEditing}">
                        <!-- Medeni Durum / GSM -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Medeni Durum" Style="{StaticResource CaptionStyle}"/>
                                <Picker ItemsSource="{Binding MaritalStatusOptions}"
                                        SelectedIndex="{Binding SelectedMaritalStatus}"
                                        FontFamily="JakartaMedium" FontSize="14"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="GSM Operatörü" Style="{StaticResource CaptionStyle}"/>
                                <Picker ItemsSource="{Binding GsmOperatorOptions}"
                                        SelectedIndex="{Binding SelectedGsmOperator}"
                                        FontFamily="JakartaMedium" FontSize="14"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- İl / İlçe -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="İl" Style="{StaticResource CaptionStyle}"/>
                                <Picker ItemsSource="{Binding Cities}"
                                        SelectedItem="{Binding SelectedCity}"
                                        ItemDisplayBinding="{Binding Name}"
                                        FontFamily="JakartaMedium" FontSize="14"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="İlçe" Style="{StaticResource CaptionStyle}"/>
                                <Picker ItemsSource="{Binding Districts}"
                                        SelectedItem="{Binding SelectedDistrict}"
                                        ItemDisplayBinding="{Binding Name}"
                                        FontFamily="JakartaMedium" FontSize="14"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Meslek (tek satır) -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Meslek" Style="{StaticResource CaptionStyle}"/>
                            <Picker ItemsSource="{Binding Professions}"
                                    SelectedItem="{Binding SelectedProfession}"
                                    ItemDisplayBinding="{Binding Name}"
                                    FontFamily="JakartaMedium" FontSize="14"/>
                        </VerticalStackLayout>

                        <!-- Eğitim Durumu (tek satır) -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Eğitim Durumu" Style="{StaticResource CaptionStyle}"/>
                            <Picker ItemsSource="{Binding EducationLevels}"
                                    SelectedItem="{Binding SelectedEducationLevel}"
                                    ItemDisplayBinding="{Binding Name}"
                                    FontFamily="JakartaMedium" FontSize="14"/>
                        </VerticalStackLayout>

                        <!-- Emekli / Hane Reisi -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <CheckBox IsChecked="{Binding IsRetired}" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                <Label Text="Emekli" FontFamily="JakartaMedium" FontSize="14"
                                       VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                <CheckBox IsChecked="{Binding IsHeadOfFamily}" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                <Label Text="Hane Reisi" FontFamily="JakartaMedium" FontSize="14"
                                       VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- Hane Reisi detayları (kendisi hane reisi değilse göster) -->
                        <VerticalStackLayout Spacing="12"
                                             IsVisible="{Binding IsHeadOfFamily, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Hane Reisi Bilgileri"
                                   FontFamily="JakartaSemiBold" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <!-- Hane Reisi Meslek (tek satır) -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Hane Reisi Meslek" Style="{StaticResource CaptionStyle}"/>
                                <Picker ItemsSource="{Binding Professions}"
                                        SelectedItem="{Binding SelectedHofProfession}"
                                        ItemDisplayBinding="{Binding Name}"
                                        FontFamily="JakartaMedium" FontSize="14"/>
                            </VerticalStackLayout>
                            <!-- Hane Reisi Eğitim (tek satır) -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Hane Reisi Eğitim Durumu" Style="{StaticResource CaptionStyle}"/>
                                <Picker ItemsSource="{Binding EducationLevels}"
                                        SelectedItem="{Binding SelectedHofEducationLevel}"
                                        ItemDisplayBinding="{Binding Name}"
                                        FontFamily="JakartaMedium" FontSize="14"/>
                            </VerticalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox IsChecked="{Binding IsHeadOfFamilyRetired}" Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"/>
                                <Label Text="Hane Reisi Emekli" FontFamily="JakartaMedium" FontSize="14"
                                       VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Kaydet / İptal -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                            <Grid HeightRequest="44">
                                <Button Text="Kaydet"
                                        Command="{Binding SaveProfileCommand}"
                                        IsVisible="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                                        FontFamily="JakartaSemiBold" FontSize="14"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                        TextColor="{StaticResource White}"
                                        CornerRadius="12"
                                        HeightRequest="44"/>
                                <Border StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                        HeightRequest="44"
                                        IsVisible="{Binding IsSaving}">
                                    <ActivityIndicator IsRunning="True"
                                                       Color="{StaticResource White}"
                                                       HeightRequest="22" WidthRequest="22"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <Button Grid.Column="1" Text="İptal"
                                    Command="{Binding CancelEditCommand}"
                                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                                    FontFamily="JakartaSemiBold" FontSize="14"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                    CornerRadius="12"
                                    HeightRequest="44"/>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Contact -->
            <Button Text="İletişim"
                    Command="{Binding GoToContactCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                    FontFamily="JakartaSemiBold" FontSize="14"
                    HeightRequest="48" CornerRadius="14"
                    Margin="0,8,0,0"/>

            <!-- Logout -->
            <Button Text="Çıkış Yap"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark={StaticResource DangerLightDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                    FontFamily="JakartaSemiBold" FontSize="14"
                    HeightRequest="48" CornerRadius="14"
                    Margin="0,4,0,0"/>

                <BoxView HeightRequest="20" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════ SHIMMER OVERLAY ══════ -->
        <Grid x:Name="ShimmerOverlay"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
              InputTransparent="True">
            <Grid x:Name="ShimmerContainer">
                <ScrollView>
                    <VerticalStackLayout Spacing="16" Padding="20,16">
                        <!-- Title -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="26" WidthRequest="70"
                                HorizontalOptions="Start"/>

                        <!-- Avatar Card -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 20"
                                Padding="20">
                            <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                                <!-- Avatar circle -->
                                <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                        StrokeShape="RoundRectangle 44"
                                        HeightRequest="88" WidthRequest="88"
                                        HorizontalOptions="Center"/>
                                <!-- Name -->
                                <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerDeep}, Dark={StaticResource ShimmerDeepDark}}"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="22" WidthRequest="160"
                                        HorizontalOptions="Center"/>
                                <!-- Referral code -->
                                <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMuted}, Dark={StaticResource ShimmerMutedDark}}"
                                        StrokeShape="RoundRectangle 12"
                                        HeightRequest="32" WidthRequest="130"
                                        HorizontalOptions="Center"/>
                                <!-- Stars -->
                                <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerMid}, Dark={StaticResource ShimmerMidDark}}"
                                        StrokeShape="RoundRectangle 6"
                                        HeightRequest="22" WidthRequest="100"
                                        HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Stats Row -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="76"/>
                            <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="76"/>
                            <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                    StrokeShape="RoundRectangle 16"
                                    HeightRequest="76"/>
                        </Grid>

                        <!-- Profile Info Card -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerBase}, Dark={StaticResource ShimmerBaseDark}}"
                                StrokeShape="RoundRectangle 20"
                                HeightRequest="280"/>

                        <!-- Contact Button -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerLight}, Dark={StaticResource ShimmerLightDark}}"
                                StrokeShape="RoundRectangle 14"
                                HeightRequest="48" Margin="0,8,0,0"/>

                        <!-- Logout Button -->
                        <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource ShimmerPink}, Dark={StaticResource ShimmerPinkDark}}"
                                StrokeShape="RoundRectangle 14"
                                HeightRequest="48" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Shimmer Sweep -->
                <Border x:Name="ShimmerSweep"
                        StrokeThickness="0"
                        WidthRequest="180"
                        Opacity="0"
                        Rotation="-18"
                        HorizontalOptions="Start"
                        VerticalOptions="Fill"
                        InputTransparent="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="{AppThemeBinding Light={StaticResource ShimmerSweepHighlight}, Dark={StaticResource ShimmerSweepHighlightDark}}" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
        <controls:CoachMarkOverlay x:Name="CoachMark" Key="profile"/>
    </Grid>
</ContentPage>
