<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PulsePoll.Mobile.Views.SurveyWebViewPage"
             x:DataType="vm:SurveyWebViewViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}">

    <Grid RowDefinitions="Auto,*"
          RowSpacing="0">
        <Grid Grid.Row="0"
              RowDefinitions="Auto"
              ColumnDefinitions="Auto,*,Auto"
              Padding="16,14,16,10"
              ZIndex="10"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}">
            <ImageButton Source="icon_arrow_left.png"
                         HeightRequest="24"
                         WidthRequest="24"
                         Command="{Binding CloseCommand}">
                <ImageButton.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </ImageButton.Behaviors>
            </ImageButton>
            <Label Grid.Column="1"
                   Text="{Binding Title}"
                   FontFamily="JakartaSemiBold"
                   FontSize="16"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"/>
            <HorizontalStackLayout Grid.Column="2"
                                   Spacing="10"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End">
                <Button Text="?"
                        Clicked="OnHelpButtonClicked"
                        IsVisible="{Binding IsHelperEnabled}"
                        WidthRequest="28"
                        HeightRequest="28"
                        Padding="0"
                        CornerRadius="14"
                        FontFamily="JakartaBold"
                        FontSize="14"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource PrimaryPurpleDark}}"/>
                <ActivityIndicator IsVisible="{Binding IsLoading}"
                                   IsRunning="{Binding IsLoading}"
                                   Color="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Grid>

        <WebView Grid.Row="1"
                 x:Name="SurveyWebView"
                 ZIndex="0"
                 Source="{Binding ResolvedUrl}"
                 Navigating="OnWebViewNavigating"
                 Navigated="OnWebViewNavigated"/>
    </Grid>
</ContentPage>
