<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="Parolamı Unuttum"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="28,32,28,0">

                <!-- Error -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                       FontFamily="JakartaMedium" FontSize="13"
                       HorizontalTextAlignment="Start"
                       IsVisible="{Binding HasError}"
                       Margin="0,0,0,12"/>

                <!-- Step 0: Phone -->
                <VerticalStackLayout Spacing="0" IsVisible="{Binding IsPhoneStep}">

                    <!-- Lock Icon -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource PrimaryMid}, Dark={StaticResource PrimaryMidDark}}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 22"
                            WidthRequest="72" HeightRequest="72"
                            HorizontalOptions="Start"
                            Margin="0,0,0,20">
                        <Image Source="icon_lock.png" WidthRequest="30" HeightRequest="30"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <Label Text="Şifreni Sıfırla"
                           Style="{StaticResource AuthTitleStyle}"
                           Margin="0,0,0,6"/>
                    <Label Text="Kayıtlı telefon numaranı gir, sana doğrulama kodu gönderelim."
                           Style="{StaticResource AuthSubtitleStyle}"
                           Margin="0,0,0,28"/>

                    <!-- Phone Field -->
                    <Label Text="TELEFON NUMARASI" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,20">
                        <Grid ColumnDefinitions="44,*" Padding="0">
                            <Image Source="icon_phone.png" WidthRequest="17" HeightRequest="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Entry Grid.Column="1" Placeholder="05XX XXX XX XX"
                                   Text="{Binding PhoneNumber}"
                                   Keyboard="Telephone" ReturnType="Done"
                                   Style="{StaticResource AuthFieldEntryStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Send Button -->
                    <Grid HeightRequest="52" Margin="0,0,0,24">
                        <Button Text="Doğrulama Kodu Gönder"
                                Command="{Binding SendOtpCommand}"
                                IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                Style="{StaticResource AuthPrimaryButtonStyle}"/>
                        <Border StrokeThickness="0"
                                StrokeShape="RoundRectangle 26"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                HeightRequest="52"
                                IsVisible="{Binding IsBusy}">
                            <ActivityIndicator IsRunning="True"
                                               Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                               HeightRequest="24" WidthRequest="24"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Info Card -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource PrimaryMid}, Dark={StaticResource PrimaryMidDark}}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="14,14,16,14">
                        <Grid ColumnDefinitions="32,*" ColumnSpacing="12">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                    StrokeShape="RoundRectangle 10" Stroke="Transparent"
                                    WidthRequest="32" HeightRequest="32"
                                    HorizontalOptions="Center" VerticalOptions="Start">
                                <Image Source="icon_info.png" WidthRequest="16" HeightRequest="16"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="SMS birkaç dakika içinde gelecektir. Lütfen bekleyin."
                                   FontFamily="JakartaRegular" FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   LineBreakMode="WordWrap"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Step 1: OTP + New Password -->
                <VerticalStackLayout Spacing="0" IsVisible="{Binding IsResetStep}">

                    <Label Text="Yeni Parola Belirle"
                           Style="{StaticResource AuthTitleStyle}"
                           Margin="0,0,0,6"/>
                    <Label Text="Telefonunuza gönderilen kodu ve yeni parolanızı girin."
                           Style="{StaticResource AuthSubtitleStyle}"
                           Margin="0,0,0,28"/>

                    <!-- OTP Code -->
                    <Label Text="DOĞRULAMA KODU" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                        <Grid ColumnDefinitions="44,*" Padding="0">
                            <Image Source="icon_lock.png" WidthRequest="17" HeightRequest="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Entry Grid.Column="1" Placeholder="6 haneli kod"
                                   Text="{Binding OtpCode}"
                                   Keyboard="Numeric" ReturnType="Next"
                                   Style="{StaticResource AuthFieldEntryStyle}"/>
                        </Grid>
                    </Border>

                    <!-- New Password -->
                    <Label Text="YENİ PAROLA" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                        <Grid ColumnDefinitions="44,*" Padding="0">
                            <Image Source="icon_lock.png" WidthRequest="17" HeightRequest="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Entry Grid.Column="1" Placeholder="En az 8 karakter"
                                   Text="{Binding NewPassword}"
                                   IsPassword="True" ReturnType="Next"
                                   Style="{StaticResource AuthFieldEntryStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Confirm Password -->
                    <Label Text="PAROLA TEKRAR" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,20">
                        <Grid ColumnDefinitions="44,*" Padding="0">
                            <Image Source="icon_lock.png" WidthRequest="17" HeightRequest="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Entry Grid.Column="1" Placeholder="Parolayı tekrar girin"
                                   Text="{Binding NewPasswordConfirm}"
                                   IsPassword="True" ReturnType="Done"
                                   Style="{StaticResource AuthFieldEntryStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Grid HeightRequest="52">
                            <Button Text="Sıfırla"
                                    Command="{Binding ResetPasswordCommand}"
                                    IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                    Style="{StaticResource AuthPrimaryButtonStyle}"/>
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 26"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                    HeightRequest="52"
                                    IsVisible="{Binding IsBusy}">
                                <ActivityIndicator IsRunning="True"
                                                   Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                                   HeightRequest="24" WidthRequest="24"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                        <Button Grid.Column="1" Text="Geri"
                                Command="{Binding GoBackCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                Style="{StaticResource AuthOutlineButtonStyle}"/>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Link -->
        <HorizontalStackLayout Grid.Row="1" Spacing="4"
                                HorizontalOptions="Center"
                                Padding="0,16,0,32">
            <Label Text="Şifreni hatırladın mı?"
                   Style="{StaticResource AuthBottomLinkStyle}"/>
            <Label Text="Giriş Yap"
                   Style="{StaticResource AuthLinkStyle}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
