<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             x:Class="PulsePoll.Mobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="Parolamı Unuttum"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="28,40" VerticalOptions="Center">

            <Label Text="Parola Sıfırlama"
                   FontFamily="JakartaBold" FontSize="24"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8"/>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontFamily="JakartaMedium" FontSize="13"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding HasError}"/>

            <!-- Adım 0: Telefon -->
            <VerticalStackLayout Spacing="16" IsVisible="{Binding IsPhoneStep}">
                <Label Text="Kayıtlı telefon numaranızı girin."
                       FontFamily="JakartaMedium" FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"/>

                <Entry Placeholder="05XX XXX XX XX"
                       Text="{Binding PhoneNumber}"
                       Keyboard="Telephone"
                       ReturnType="Done"
                       FontFamily="JakartaMedium" FontSize="15"/>

                <Button Text="Kod Gönder"
                        Command="{Binding SendOtpCommand}"
                        BackgroundColor="{StaticResource PrimaryPurple}"
                        TextColor="White"
                        FontFamily="JakartaBold" FontSize="16"
                        HeightRequest="52" CornerRadius="14"/>
            </VerticalStackLayout>

            <!-- Adım 1: OTP + Yeni Parola -->
            <VerticalStackLayout Spacing="16" IsVisible="{Binding IsResetStep}">
                <Label Text="Telefonunuza gönderilen kodu ve yeni parolanızı girin."
                       FontFamily="JakartaMedium" FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"/>

                <Entry Placeholder="Doğrulama Kodu"
                       Text="{Binding OtpCode}"
                       Keyboard="Numeric"
                       FontFamily="JakartaMedium" FontSize="15"/>

                <Entry Placeholder="Yeni Parola"
                       Text="{Binding NewPassword}"
                       IsPassword="True"
                       FontFamily="JakartaMedium" FontSize="15"/>

                <Entry Placeholder="Yeni Parola (Tekrar)"
                       Text="{Binding NewPasswordConfirm}"
                       IsPassword="True"
                       FontFamily="JakartaMedium" FontSize="15"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Text="Sıfırla"
                            Command="{Binding ResetPasswordCommand}"
                            BackgroundColor="{StaticResource PrimaryPurple}"
                            TextColor="White"
                            FontFamily="JakartaBold" FontSize="15"
                            HeightRequest="48" CornerRadius="14"/>
                    <Button Grid.Column="1" Text="Geri"
                            Command="{Binding GoBackCommand}"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            TextColor="{StaticResource PrimaryPurple}"
                            FontFamily="JakartaBold" FontSize="15"
                            HeightRequest="48" CornerRadius="14"/>
                </Grid>
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryPurple}"
                               HeightRequest="30"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
