<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             x:Class="PulsePoll.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Giriş Yap"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="28,40" VerticalOptions="Center">

            <Label Text="PulsePoll"
                   FontFamily="JakartaBold" FontSize="34"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource PrimaryPurple}"
                   Margin="0,0,0,4"/>

            <Label Text="Hesabınıza giriş yapın"
                   FontFamily="JakartaMedium" FontSize="15"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="0,0,0,20"/>

            <Entry Placeholder="E-posta"
                   Text="{Binding Email}"
                   Keyboard="Email"
                   ReturnType="Next"
                   FontFamily="JakartaMedium" FontSize="15"/>

            <Entry Placeholder="Parola"
                   Text="{Binding Password}"
                   IsPassword="True"
                   ReturnType="Done"
                   FontFamily="JakartaMedium" FontSize="15"/>

            <Label Text="Parolamı Unuttum"
                   FontFamily="JakartaSemiBold" FontSize="13"
                   TextColor="{StaticResource PrimaryPurple}"
                   HorizontalTextAlignment="End"
                   Margin="0,-4,4,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontFamily="JakartaMedium" FontSize="13"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding HasError}"/>

            <Button Text="Giriş Yap"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="{StaticResource PrimaryPurple}"
                    TextColor="White"
                    FontFamily="JakartaBold" FontSize="16"
                    HeightRequest="52"
                    CornerRadius="14"
                    Margin="0,8,0,0"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryPurple}"
                               HeightRequest="30"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
