<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Giriş Yap"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="28,28,28,0">

                <!-- Logo Mark -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                        StrokeShape="RoundRectangle 22" Stroke="Transparent"
                        WidthRequest="72" HeightRequest="72"
                        HorizontalOptions="Start"
                        Margin="0,0,0,20">
                    <Image Source="icon_pulse.png" WidthRequest="32" HeightRequest="32"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <!-- Title -->
                <Label Text="Tekrar Hoş Geldin"
                       Style="{StaticResource AuthTitleStyle}"
                       Margin="0,0,0,6"/>
                <Label Text="Hesabına giriş yap ve anketlere katılmaya devam et."
                       Style="{StaticResource AuthSubtitleStyle}"
                       Margin="0,0,0,28"/>

                <!-- Error -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                       FontFamily="JakartaMedium" FontSize="13"
                       HorizontalTextAlignment="Start"
                       IsVisible="{Binding HasError}"
                       Margin="0,0,0,12"/>

                <!-- Phone Field -->
                <Label Text="TELEFON" Style="{StaticResource FieldLabelStyle}"/>
                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,14">
                    <Grid ColumnDefinitions="44,*" Padding="0">
                        <Image Source="icon_phone.png" WidthRequest="17" HeightRequest="17"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" Placeholder="05XX XXX XX XX"
                               Text="{Binding PhoneNumber}"
                               Keyboard="Telephone" ReturnType="Next"
                               Style="{StaticResource AuthFieldEntryStyle}"/>
                    </Grid>
                </Border>

                <!-- Password Field with Forgot Password link -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <Label Text="ŞİFRE" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                    <Label Grid.Column="1" Text="Şifremi Unuttum"
                           FontFamily="JakartaSemiBold" FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
                <Border Style="{StaticResource AuthFieldBorderStyle}" Margin="0,0,0,18">
                    <Grid ColumnDefinitions="44,*" Padding="0">
                        <Image Source="icon_lock.png" WidthRequest="17" HeightRequest="17"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" Placeholder="Parolanızı girin"
                               Text="{Binding Password}"
                               IsPassword="True" ReturnType="Done"
                               Style="{StaticResource AuthFieldEntryStyle}"/>
                    </Grid>
                </Border>

                <!-- Login Button -->
                <Grid HeightRequest="52" Margin="0,0,0,4">
                    <Button Text="Giriş Yap"
                            Command="{Binding LoginCommand}"
                            IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            Style="{StaticResource AuthPrimaryButtonStyle}"/>
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 26"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                            HeightRequest="52"
                            IsVisible="{Binding IsBusy}">
                        <ActivityIndicator IsRunning="True"
                                           Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                           HeightRequest="24" WidthRequest="24"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Link -->
        <HorizontalStackLayout Grid.Row="1" Spacing="4"
                                HorizontalOptions="Center"
                                Padding="0,16,0,32">
            <Label Text="Hesabın yok mu?"
                   Style="{StaticResource AuthBottomLinkStyle}"/>
            <Label Text="Kayıt Ol"
                   Style="{StaticResource AuthLinkStyle}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
