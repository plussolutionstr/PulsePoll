<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PulsePoll.Mobile.ViewModels"
             xmlns:converters="clr-namespace:PulsePoll.Mobile.Converters"
             x:Class="PulsePoll.Mobile.Views.WalletAddBankAccountPage"
             x:DataType="viewModels:WalletAddBankAccountViewModel"
             Title="Banka Hesabı Ekle">

    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <!-- Bank Selection -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Banka"
                           FontFamily="JakartaSemiBold"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
                            Padding="12,0">
                        <Picker Title="Banka seçin"
                                ItemsSource="{Binding Banks}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedBank}"
                                FontFamily="JakartaSemiBold"
                                FontSize="15"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                HeightRequest="48"
                                VerticalOptions="Center" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- IBAN Entry -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="IBAN"
                           FontFamily="JakartaSemiBold"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}"
                            Padding="0">
                        <Grid ColumnDefinitions="48,*">
                            <Label Text="TR"
                                   FontFamily="JakartaBold" FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Entry Grid.Column="1"
                                   Placeholder="00 0000 0000 0000 0000 0000 00"
                                   Text="{Binding Iban}"
                                   Keyboard="Text"
                                   MaxLength="34"
                                   FontFamily="JakartaRegular"
                                   FontSize="14" />
                        </Grid>
                    </Border>

                    <!-- IBAN Hint -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                            Padding="12,10">
                        <Label Text="26 karakter uzunluğunda, TR ile başlayan IBAN numaranızı girin."
                               FontFamily="JakartaRegular"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource PrimaryDarkDark}}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Buttons -->
            <Grid HeightRequest="52">
                <Button Text="Kaydet"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                        Clicked="OnSaveClicked" />
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 26"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                        HeightRequest="52"
                        IsVisible="{Binding IsSaving}">
                    <ActivityIndicator IsRunning="True"
                                       Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WhiteDark}}"
                                       HeightRequest="24" WidthRequest="24"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <Button Text="İptal"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HeightRequest="52"
                    CornerRadius="26"
                    HorizontalOptions="Fill"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                    Clicked="OnCancelClicked" />

            <BoxView HeightRequest="20" Color="Transparent"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
