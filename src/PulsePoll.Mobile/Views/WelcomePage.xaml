<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PulsePoll.Mobile.ViewModels"
             x:Class="PulsePoll.Mobile.Views.WelcomePage"
             x:DataType="vm:WelcomeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="28,0" VerticalOptions="Center">

            <!-- Illustration Area -->
            <Grid HorizontalOptions="Center" WidthRequest="200" HeightRequest="200" Margin="0,40,0,0">
                <!-- Background circle -->
                <Ellipse Fill="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                         WidthRequest="200" HeightRequest="200"
                         HorizontalOptions="Center" VerticalOptions="Center"/>

                <!-- Central logo box -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                        StrokeShape="RoundRectangle 26"
                        Stroke="Transparent"
                        WidthRequest="88" HeightRequest="88"
                        HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="icon_pulse.png" WidthRequest="38" HeightRequest="38"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <!-- TL circle (top-right) -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource AmberLight}, Dark={StaticResource AmberLightDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource Amber}, Dark={StaticResource AmberDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        WidthRequest="40" HeightRequest="40"
                        HorizontalOptions="End" VerticalOptions="Start"
                        Margin="0,10,10,0">
                    <Label Text="&#x20BA;" FontFamily="JakartaBold" FontSize="18"
                           TextColor="{AppThemeBinding Light={StaticResource Amber}, Dark={StaticResource AmberDark}}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <!-- Check circle (bottom-left) -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SuccessLight}, Dark={StaticResource SuccessLightDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource SuccessDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        WidthRequest="36" HeightRequest="36"
                        HorizontalOptions="Start" VerticalOptions="End"
                        Margin="4,0,0,8">
                    <Image Source="icon_check.png" WidthRequest="16" HeightRequest="16"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- Title -->
            <Label Text="PulsePoll"
                   FontFamily="JakartaExtraBold" FontSize="26"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryPurple}, Dark={StaticResource PrimaryPurpleDark}}"
                   HorizontalTextAlignment="Center"
                   Margin="0,36,0,4"/>

            <Label Text="Ankete Katıl,&#x0a;Kazanmaya Başla"
                   FontFamily="JakartaExtraBold" FontSize="22"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"
                   Margin="0,0,0,10"/>

            <Label Text="Türkiye'nin en güvenilir anket platformunda fikirlerini paylaş, anında kazan."
                   FontFamily="JakartaRegular" FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"
                   Margin="10,0,10,8"/>

            <!-- Feature Pills -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,6,0,28">
                <!-- Kisa Anketler -->
                <Border Style="{StaticResource FeaturePillStyle}">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                StrokeShape="RoundRectangle 11" Stroke="Transparent"
                                WidthRequest="36" HeightRequest="36"
                                HorizontalOptions="Center">
                            <Image Source="icon_survey_check.png" WidthRequest="17" HeightRequest="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Kısa&#x0a;Anketler" FontFamily="JakartaSemiBold" FontSize="10"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalTextAlignment="Center" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Aninda Kazanc -->
                <Border Grid.Column="1" Style="{StaticResource FeaturePillStyle}">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource AmberLight}, Dark={StaticResource AmberLightDark}}"
                                StrokeShape="RoundRectangle 11" Stroke="Transparent"
                                WidthRequest="36" HeightRequest="36"
                                HorizontalOptions="Center">
                            <Label Text="&#x20BA;" FontFamily="JakartaBold" FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource Amber}, Dark={StaticResource AmberDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Anında&#x0a;Kazanç" FontFamily="JakartaSemiBold" FontSize="10"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalTextAlignment="Center" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Kolay Cekim -->
                <Border Grid.Column="2" Style="{StaticResource FeaturePillStyle}">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource SuccessLight}, Dark={StaticResource SuccessLightDark}}"
                                StrokeShape="RoundRectangle 11" Stroke="Transparent"
                                WidthRequest="36" HeightRequest="36"
                                HorizontalOptions="Center">
                            <Image Source="icon_card.png" WidthRequest="17" HeightRequest="17"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Kolay&#x0a;Çekim" FontFamily="JakartaSemiBold" FontSize="10"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalTextAlignment="Center" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Buttons -->
            <Button Text="Hemen Başla"
                    Command="{Binding GoToRegisterCommand}"
                    Style="{StaticResource AuthPrimaryButtonStyle}"
                    Margin="0,0,0,10"/>

            <Button Text="Zaten hesabım var"
                    Command="{Binding GoToLoginCommand}"
                    Style="{StaticResource AuthOutlineButtonStyle}"
                    Margin="0,0,0,40"/>

            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,0,0,32">
                <Label Text="Sorun mu yaşıyorsun?"
                       Style="{StaticResource AuthBottomLinkStyle}"/>
                <Label Text="İletişim"
                       Style="{StaticResource AuthLinkStyle}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToContactCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
